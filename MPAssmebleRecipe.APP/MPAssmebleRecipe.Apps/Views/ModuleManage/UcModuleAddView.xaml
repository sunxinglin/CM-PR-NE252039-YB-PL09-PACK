<UserControl x:Class="MPAssmebleRecipe.Apps.Views.ModuleManage.UcModuleAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
            xmlns:enum="clr-namespace:RogerTech.Common.Models;assembly=RogerTech.Common"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:module="clr-namespace:MPAssmebleRecipe.Apps.Views.ModuleManage"
             Width="900" Height="850">

    <!-- 添加枚举资源 -->
    <UserControl.Resources>
        <ObjectDataProvider x:Key="CellSideTapeTypeEnum" 
                          MethodName="GetValues"
                          ObjectType="{x:Type enum:CellSideTapeType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enum:CellSideTapeType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- 模组定义 -->
        <GroupBox Grid.Column="0" Header="模组定义" Style="{StaticResource MaterialDesignGroupBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.6*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="模组名称" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="10,0"
                         Text="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Text="模组Pn" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,0"
                         Text="{Binding ModulePn, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Text="电芯数量" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="10,0"
                         Text="{Binding CellCount, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Row="6" Grid.Column="1" Margin="5"
                        Content="保存模组配置"
                        Command="{Binding SaveModuleCommand}"
                        IsEnabled="{Binding CanSaveModule}"/>
            </Grid>
        </GroupBox>

        <!-- 模组预览 -->
        <GroupBox Grid.Column="1" Header="模组预览" Style="{StaticResource MaterialDesignGroupBox}">
            <Grid>
                <module:UcModuleDisplayView DataContext="{Binding ModuleDisplay}"/>
            </Grid>
        </GroupBox>

        <!-- 电芯预览 -->
        <GroupBox Grid.Column="2" Header="电芯预览" Style="{StaticResource MaterialDesignGroupBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="序号" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Grid.ColumnSpan="2" Margin="5"
                                ItemsSource="{Binding CellTemplates}"
                                SelectedItem="{Binding SelectedCellTemplate}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CellIndex}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Text="极性" VerticalAlignment="Center"/>
                    <RadioButton Grid.Row="1" Grid.Column="1" Content="正"
                                IsChecked="{Binding IsPositive}"/>
                    <RadioButton Grid.Row="1" Grid.Column="2" Content="负"
                                IsChecked="{Binding IsNegative}"/>

                    <TextBlock Grid.Row="2" Text="大面前贴胶" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="2" 
                            ItemsSource="{Binding Source={StaticResource CellSideTapeTypeEnum}}"
                            SelectedItem="{Binding FrontTape}"
                            Margin="0,0,0,15">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="3" Text="大面后贴胶" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="3" Grid.Column="2"  
                              ItemsSource="{Binding Source={StaticResource CellSideTapeTypeEnum}}"
                              SelectedItem="{Binding BackTape}"
                              Margin="0,0,0,15">    
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Button Grid.Row="2" Margin="5" Content="保存电芯配置"
                        Command="{Binding SaveCellCommand}"/>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>