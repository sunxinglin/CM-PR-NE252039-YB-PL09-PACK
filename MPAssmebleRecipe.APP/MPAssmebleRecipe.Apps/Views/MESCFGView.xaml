<UserControl x:Class="MPAssmebleRecipe.Apps.Views.MESCFGView"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         mc:Ignorable="d" 
         xmlns:MaterialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
         xmlns:prism="http://prismlibrary.com/"
         d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <ListView Name="InterfaceList" Grid.Column="0" ItemsSource="{Binding MenuItems}"
                SelectedItem="{Binding SelectedMenuItem}" 
                
                SelectionChanged="SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Height="30" >
                        <MaterialDesign:PackIcon VerticalAlignment="Center" Width="25" Height="25" Kind="{Binding Icon}"
                               Margin="0,0,8,0"/>
                        <TextBlock VerticalAlignment="Center" FontSize="15" Text="{Binding Title}"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Grid   Grid.Column="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" 
               Orientation="Horizontal" 
               Margin="16,8">
                <Label Content="{Binding InterfaceName}"
                       FontSize="15" 
                       Width="NaN"
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       Style="{StaticResource MaterialDesignLabel}"

                       Background="Transparent"
                       Margin="10,10,10,10"/>


                <Button Margin="16,0"
                        Name="保存"
               Style="{StaticResource MaterialDesignRaisedButton}"
              Click="SaveSetting">
                    <StackPanel Orientation="Horizontal">
                        <MaterialDesign:PackIcon Kind="Filter" 
                                      VerticalAlignment="Center"/>
                        <TextBlock Text="保存" 
                        Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>


            </StackPanel>
            <Grid Name="NameGrid" Grid.Row="1"  Grid.Column="0"/>
        </Grid>

    </Grid>
</UserControl>
