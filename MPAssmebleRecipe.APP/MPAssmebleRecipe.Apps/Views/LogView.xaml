<UserControl x:Class="MPAssmebleRecipe.Apps.Views.LogView"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         mc:Ignorable="d" 
         xmlns:MaterialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
         xmlns:prism="http://prismlibrary.com/"
         d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"></ColumnDefinition>
            <ColumnDefinition Width="49*"></ColumnDefinition>
            <ColumnDefinition Width="276*"/>
        </Grid.ColumnDefinitions>

        <ListView Grid.Column="0" ItemsSource="{Binding MenuItems}"
                SelectedItem="{Binding SelectedMenuItem}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Height="30" >
                        <MaterialDesign:PackIcon VerticalAlignment="Center" Width="25" Height="25" Kind="{Binding Icon}"
                               Margin="0,0,8,0"/>
                        <TextBlock VerticalAlignment="Center" FontSize="15" Text="{Binding Title}"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Grid Grid.Column="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <!-- 工具栏 -->
            <StackPanel Grid.Row="0" 
                Orientation="Horizontal" 
                Margin="16,8">
                <CheckBox Content="启用时间筛选"
                  IsChecked="{Binding IsTimeFilterEnabled}"
                  Style="{StaticResource MaterialDesignCheckBox}"
                  VerticalAlignment="Center"/>

                <DatePicker Margin="16,0,0,0"
                    Width="120"
                    MaterialDesign:HintAssist.Hint="开始日期"
                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                    SelectedDate="{Binding StartDate}"
                    IsEnabled="{Binding IsTimeFilterEnabled}"/>

                <MaterialDesign:TimePicker Margin="8,0"
                    Width="120"
                    MaterialDesign:HintAssist.Hint="开始时间"
                    Style="{StaticResource MaterialDesignFloatingHintTimePicker}"
                    SelectedTime="{Binding StartTime}"
                    IsEnabled="{Binding IsTimeFilterEnabled}"/>

                <DatePicker Width="120"
                    MaterialDesign:HintAssist.Hint="结束日期"
                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                    SelectedDate="{Binding EndDate}"
                    IsEnabled="{Binding IsTimeFilterEnabled}"/>

                <MaterialDesign:TimePicker Margin="8,0"
                    Width="120"
                    MaterialDesign:HintAssist.Hint="结束时间"
                    Style="{StaticResource MaterialDesignFloatingHintTimePicker}"
                    SelectedTime="{Binding EndTime}"
                    IsEnabled="{Binding IsTimeFilterEnabled}"/>

                <Button Margin="16,0"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Command="{Binding ApplyFilterCommand}">
                    <StackPanel Orientation="Horizontal">
                        <MaterialDesign:PackIcon Kind="Filter" 
                                       VerticalAlignment="Center"/>
                        <TextBlock Text="应用筛选" 
                         Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <MaterialDesign:PackIcon Kind="Refresh" 
                                       VerticalAlignment="Center"/>
                        <TextBlock Text="刷新" 
                         Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- 日志列表 -->
            <DataGrid Grid.Row="1" 
              ItemsSource="{Binding FilteredLogs}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              IsReadOnly="True"
              MaterialDesign:DataGridAssist.CellPadding="5 2 2 2"
              MaterialDesign:DataGridAssist.ColumnHeaderPadding="4"
              MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Result}" Value="0">
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Result, Converter={StaticResource NotEqualToZeroConverter}}" Value="True">
                                <Setter Property="Foreground" Value="Red" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间" 
                              Binding="{Binding RecordTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                              Width="160"/>
                    <DataGridTextColumn Header="产品ID" 
                              Binding="{Binding ProductID}"
                              Width="220"/>
                    <DataGridTextColumn Header="接口名称" 
                              Binding="{Binding InterfaceName}"
                              Width="100"/>
                    <DataGridTextColumn Header="日志类型" 
                              Binding="{Binding LogType}"
                              Width="60"/>
                    <DataGridTextColumn Header="结果代码" 
                              Binding="{Binding Result}"
                              Width="80"/>
                    <DataGridTextColumn Header="内容" 
                              Binding="{Binding Message}"
                              Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn >
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
