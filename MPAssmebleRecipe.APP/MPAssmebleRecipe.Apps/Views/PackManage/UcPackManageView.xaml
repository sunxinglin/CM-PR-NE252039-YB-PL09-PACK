<UserControl
    x:Class="MPAssmebleRecipe.Apps.Views.PackManage.UcPackManageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MPAssmebleRecipe.Apps.Views.PackManage"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:module="clr-namespace:MPAssmebleRecipe.Apps.Views.ModuleManage"
    xmlns:packmanage="clr-namespace:MPAssmebleRecipe.Apps.ViewModels.PackManage"
    xmlns:prism="http://prismlibrary.com/"
    d:DataContext="{d:DesignInstance Type=packmanage:UcPackManageViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="1200"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="Transparent"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  定义样式  -->
        <Style x:Key="BoolIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="Red" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                    <Setter Property="Text" Value="&#xE73E;" />
                    <!--  勾选图标  -->
                    <Setter Property="Foreground" Value="Green" />
                    <Setter Property="ToolTip" Value="+" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Text" Value="&#xE711;" />
                    <!--  关闭图标  -->
                    <Setter Property="Foreground" Value="Red" />
                    <Setter Property="ToolTip" Value="-" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!--  左侧主要内容区域  -->
        <Border
            Grid.Column="0"
            Background="White"
            CornerRadius="15"
            Effect="{DynamicResource MaterialDesignElevationShadow2}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Pack列表  -->
                <GroupBox
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    FontSize="15"
                    Header="Pack列表">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Name="添加PACK"
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Command="{Binding AddPackCommand}"
                                Content="添加" />
                            <Button
                                Name="删除PACK"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Command="{Binding DeletePackCommand}"
                                Content="删除" />
                        </Grid>

                        <DataGrid
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            IsReadOnly="True"
                            ItemsSource="{Binding Packs, Mode=TwoWay}"
                            SelectedIndex="0"
                            SelectedItem="{Binding SelectedPack, Mode=TwoWay}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding PackName}"
                                    Header="Pack名称" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding PackPn}"
                                    Header="Pack料号" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding LayerTotal}"
                                    Header="层数" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <!--  Block列表  -->
                <GroupBox
                    Grid.Row="0"
                    Grid.Column="1"
                    FontSize="15"
                    Header="Block列表">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Name="添加BLOCK"
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Command="{Binding AddBlockCommand}"
                                Content="添加" />
                            <Button
                                Name="删除BLOCK"
                                Grid.Column="1"
                                Margin="8,0,8,0"
                                Command="{Binding DelBlockCommand}"
                                Content="删除" />
                            <Button
                                Name="维护Block"
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                Command="{Binding EditBlockCommand}"
                                Content="维护Block" />
                        </Grid>

                        <DataGrid
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            IsReadOnly="True"
                            ItemsSource="{Binding BlocksItems}"
                            SelectedItem="{Binding SelectedBlock}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding BlockName}"
                                    Header="Block名称" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding BlockPn}"
                                    Header="Block料号" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding BlockSequence}"
                                    Header="AGV托盘号" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding BlockAmount}"
                                    Header="Block数量" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding BlockIndex}"
                                    Header="Block序号" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding ModuleAmount}"
                                    Header="Unit数量" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding LayerNum}"
                                    Header="Pack层号" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <!--  Module列表  -->
                <GroupBox
                    Grid.Row="1"
                    Grid.Column="1"
                    FontSize="15"
                    Header="Unit列表">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Name="维护Unit"
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                Command="{Binding EditModuleCommand}"
                                Content="维护Unit" />
                            <Button
                                Name="维护电芯"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Command="{Binding EditCellCommand}"
                                Content="维护电芯"
                                Cursor="Hand" />
                        </Grid>

                        <DataGrid
                            Grid.Row="1"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            IsReadOnly="True"
                            ItemsSource="{Binding ModulesItems}"
                            SelectedItem="{Binding SelectedModule, Mode=TwoWay}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding BlockPn}"
                                    Header="Block料号" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding BlockSequence}"
                                    Header="AGV托盘号" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding ModuleType}"
                                    Header="Unit类型" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding ModuleIndex}"
                                    Header="Unit序号" />
                                <DataGridCheckBoxColumn
                                    Width="1*"
                                    Binding="{Binding ModulePolarity}"
                                    Header="Unit极性" />
                                <!--<DataGridCheckBoxColumn Width="1*" Header="Unit极性">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="IsChecked" Value="{Binding ModulePolarity}" />
                                            <Setter Property="Content" Value="-" />
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="+" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>-->
                                <DataGridCheckBoxColumn
                                    Width="1*"
                                    Binding="{Binding ModuleRotate}"
                                    Header="Unit旋转" />
                                <DataGridTextColumn
                                    Width="1*"
                                    Binding="{Binding CellAmount}"
                                    Header="电芯数量" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <!--  Unit显示  -->
                <GroupBox
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="2"
                    FontSize="15"
                    Header="Unit显示">
                    <Grid>
                        <module:UcModuleDisplayView DataContext="{Binding ModuleDisplay}" />
                    </Grid>
                </GroupBox>
            </Grid>
        </Border>

