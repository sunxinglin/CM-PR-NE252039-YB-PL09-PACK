<UserControl x:Class="MPAssmebleRecipe.Apps.Views.CellManage.UcCurrentCellOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:MPAssmebleRecipe.Apps.ViewModels.CellManage"
             d:DataContext="{d:DesignInstance Type=vm:UcCurrentCellOrderViewModel}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">
    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="15"
                Effect="{DynamicResource MaterialDesignElevationShadow2}">
            <Grid Margin="20">
                <DataGrid IsReadOnly="True" 
                         CanUserAddRows="False" 
                         AutoGenerateColumns="False"
                         Background="Transparent"
                         BorderThickness="1"
                         BorderBrush="#E0E0E0"
                         RowBackground="White"
                         AlternatingRowBackground="#F5F5F5"
                         GridLinesVisibility="All"
                         VerticalGridLinesBrush="#E0E0E0"
                         HorizontalGridLinesBrush="#E0E0E0"
                         ItemsSource="{Binding CellItems}">

                    <!-- DataGrid样式 -->
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F5F6FA"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <!--<Setter Property="Background" Value="Transparent" />-->
                            <Setter Property="AllowDrop" Value="{Binding CellComplete}" />
                            <Style.Triggers>
                                <Trigger Property="AllowDrop" Value="True">
                                    <Setter Property="Background" Value="LightGreen" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="下发顺序" Binding="{Binding DownLoadIndex}"/>
                        <DataGridTextColumn Header="BName" Binding="{Binding BlockName}"/>
                        <DataGridTextColumn Header="Block排序" Binding="{Binding BlockIndex}"/>
                        <DataGridTextColumn Header="模组排序" Binding="{Binding ModuleIndex}"/>
                        <DataGridTextColumn Header="电芯排序" Binding="{Binding CellIndex}"/>
                        <DataGridTextColumn Header="电芯极性" Binding="{Binding CellPolarity}"/>
                        <DataGridTextColumn Header="BlockName" Binding="{Binding BlockName}"/>
                        <DataGridTextColumn Header="电芯左侧贴胶" Binding="{Binding Side1Tape}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="AllowDrop" Value="{Binding Side1Tape}" />
                                    <Style.Triggers>
                                        <Trigger Property="AllowDrop" Value="True">
                                            <Setter Property="Background" Value="Yellow"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="电芯右侧贴胶" Binding="{Binding Side2Tape}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="AllowDrop" Value="{Binding Side2Tape}" />
                                    <Style.Triggers>
                                        <Trigger Property="AllowDrop" Value="True">
                                            <Setter Property="Background" Value="Yellow"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="下发状态" Binding="{Binding CellComplete}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="AllowDrop" Value="{Binding CellComplete}" />
                                    <Style.Triggers>
                                        <Trigger Property="AllowDrop" Value="True">
                                            <Setter Property="Background" Value="LightGreen"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="电芯码" Binding="{Binding CellSn}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>