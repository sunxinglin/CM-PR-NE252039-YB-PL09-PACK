<UserControl
    x:Class="MPAssmebleRecipe.Apps.Views.CellManage.UcCellEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:MaterialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="clr-namespace:RogerTech.Common.Models;assembly=RogerTech.Common"
    xmlns:local="clr-namespace:MPAssmebleRecipe.Apps.Views.CellManage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="600"
    Height="600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ObjectDataProvider
            x:Key="CellFaceTapeTypeEnum"
            MethodName="GetValues"
            ObjectType="{x:Type enum:CellFaceTapeType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enum:CellFaceTapeType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider
            x:Key="CellSideTapeTypeEnum"
            MethodName="GetValues"
            ObjectType="{x:Type enum:CellSideTapeType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enum:CellSideTapeType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <Button
                Width="200"
                Margin="0,0,20,0"
                Command="{Binding SaveCommand}"
                Content="保存"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button
                Width="200"
                Margin="0,0,20,0"
                Command="{Binding CancelCommand}"
                Content="取消"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>
        <DataGrid
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            ItemsSource="{Binding CellItems}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Binding="{Binding BlockPn, Mode=TwoWay}"
                    Header="Block料号"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Binding="{Binding CellIndex, Mode=TwoWay}"
                    Header="电芯序号"
                    IsReadOnly="True" />
                <DataGridCheckBoxColumn
                    Binding="{Binding Polarity, Mode=TwoWay}"
                    Header="电芯极性"
                    IsReadOnly="False" />
                <MaterialDesign:DataGridComboBoxColumn
                    x:Name="Side1TapeColumn"
                    Header="大面胶类型"
                    IsReadOnly="False"
                    ItemsSource="{Binding Source={StaticResource CellFaceTapeTypeEnum}}"
                    SelectedItemBinding="{Binding Side1Tape, Mode=TwoWay}" />
                <MaterialDesign:DataGridComboBoxColumn
                    x:Name="Side2TapeColumn"
                    Header="小面胶类型"
                    IsReadOnly="False"
                    ItemsSource="{Binding Source={StaticResource CellSideTapeTypeEnum}}"
                    SelectedItemBinding="{Binding Side2Tape, Mode=TwoWay}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
