<UserControl x:Class="MPAssmebleRecipe.Apps.Views.CodeDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:MPAssmebleRecipe.Apps.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:CodeDetailViewModel}"
             mc:Ignorable="d"
             Width="600" Height="500">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 错误代码标题 -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,16">
            <TextBlock Text="错误代码: " 
                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
            <TextBlock Text="{Binding Code}" 
                     Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
        </StackPanel>

        <!-- 错误信息列表 -->
        <ScrollViewer Grid.Row="1" 
                     VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ErrorInfos}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,0,0,8">
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <DockPanel Grid.Row="0">
                                    <TextBlock Text="错误描述"
                                             Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                             Opacity="0.6"/>
                                    <TextBlock Text="{Binding Description}"
                                             Style="{StaticResource MaterialDesignBody2TextBlock}"
                                             TextWrapping="Wrap"
                                             Margin="8,4,0,8"/>
                                </DockPanel>

                                <DockPanel Grid.Row="1">
                                    <TextBlock Text="解决方案"
                                             Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                             Opacity="0.6"/>
                                    <TextBlock Text="{Binding Solution}"
                                             Style="{StaticResource MaterialDesignBody2TextBlock}"
                                             TextWrapping="Wrap"
                                             Margin="8,4,0,0"/>
                                </DockPanel>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 关闭按钮 -->
        <Button Grid.Row="2"
                Style="{StaticResource MaterialDesignFlatButton}"
                Command="{Binding CloseCommand}"
                Content="关闭"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"/>
    </Grid>
</UserControl>
