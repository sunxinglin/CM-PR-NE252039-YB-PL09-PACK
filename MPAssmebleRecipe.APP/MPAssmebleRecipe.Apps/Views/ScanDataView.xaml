<UserControl x:Class="MPAssmebleRecipe.Apps.Views.ScanDataView"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         mc:Ignorable="d" 
         xmlns:MaterialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
         xmlns:prism="http://prismlibrary.com/"
         d:DesignHeight="450" d:DesignWidth="1441.825">


    <Grid Grid.Column="0" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="61*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" 
                Orientation="Horizontal" 
                Margin="20,10,20,10" Grid.ColumnSpan="2">

            <DatePicker Margin="16,0,0,0"
                    Width="120"  VerticalAlignment="Center"
                    MaterialDesign:HintAssist.Hint="开始日期"
                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}" 
                    SelectedDate="{Binding StartDate}"
                   />

            <MaterialDesign:TimePicker Margin="8,0"
                    Width="120"
                    MaterialDesign:HintAssist.Hint="开始时间"
                    Style="{StaticResource MaterialDesignFloatingHintTimePicker}"
                    SelectedTime="{Binding StartTime}"
                   />

            <DatePicker Width="120"  VerticalAlignment="Center"
                    MaterialDesign:HintAssist.Hint="结束日期"
                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                    SelectedDate="{Binding EndDate}"
                    />

            <MaterialDesign:TimePicker Margin="8,0"
                    Width="120"
                    MaterialDesign:HintAssist.Hint="结束时间"
                    Style="{StaticResource MaterialDesignFloatingHintTimePicker}"
                    SelectedTime="{Binding EndTime}"
                    />

            <TextBox Text="{Binding SFC}"
                    MaterialDesign:HintAssist.Hint="SFC条码/物料码"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Margin="8,0" Width="250"/>

            <Button Margin="10,0" Name="ReflashBtn" Style="{StaticResource MaterialDesignRaisedButton}"  Width="120" Height="35"
                Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <MaterialDesign:PackIcon Kind="Search" 
                                       VerticalAlignment="Center"/>
                    <TextBlock Text="查询" 
                         Margin="4,0,0,0"/>
                </StackPanel>
            </Button>

            <Button Margin="10,0" Name="UpLoadBtn" Style="{StaticResource MaterialDesignRaisedButton}"  Width="120" Height="35">
                <StackPanel Orientation="Horizontal">
                    <MaterialDesign:PackIcon Kind="Upload" 
                           VerticalAlignment="Center"/>
                    <TextBlock Text="重新上传" 
             Margin="4,0,0,0"/>

                </StackPanel>
            </Button>

            <Button Margin="10,0" Name="UnBindBtn" Style="{StaticResource MaterialDesignRaisedButton}"  
                    Width="120" Height="35">
                <StackPanel Orientation="Horizontal">
                    <MaterialDesign:PackIcon Kind="DeleteCircle" 
                VerticalAlignment="Center"/>
                    <TextBlock Text="物料解绑" 
                  Margin="4,0,0,0"/>
                </StackPanel>
            </Button>

            <Button Margin="10,0" Name="ReplaceMateBtn" Style="{StaticResource MaterialDesignRaisedButton}"  
         Width="120" Height="35">
                <StackPanel Orientation="Horizontal">
                    <MaterialDesign:PackIcon Kind="DeleteCircle" 
     VerticalAlignment="Center"/>
                    <TextBlock Text="物料更换" 
       Margin="4,0,0,0"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- 数据列表 -->
        <DataGrid x:Name="dataGrid" Grid.Row="1" Margin="20,10" SelectionMode="Extended"
              ItemsSource="{Binding Datas}" ColumnHeaderHeight="40" RowHeight="35" 
              AutoGenerateColumns="False"  VerticalContentAlignment="Center"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              IsReadOnly="True"
              MaterialDesign:DataGridAssist.CellPadding="5 2 2 2"
              MaterialDesign:DataGridAssist.ColumnHeaderPadding="4"
              MouseDoubleClick="DataGrid_MouseDoubleClick">
            <!--<DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsUpload}" Value="0">
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsUpload, Converter={StaticResource NotEqualToZeroConverter}}" Value="True">
                            <Setter Property="Foreground" Value="Red" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>-->
            <DataGrid.Columns>
                <!--<DataGridTemplateColumn Header="选中" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                    HorizontalAlignment="Center"
                      Width="auto"
                    Style="{StaticResource MaterialDesignCheckBox}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
                <DataGridTextColumn Header="SFC" 
                              Binding="{Binding SFC}"
                              Width="200"/>
                <DataGridTextColumn Header="物料条码" 
                              Binding="{Binding MaterialSN}"
                              Width="200"/>
                <DataGridTextColumn Header="物料PN" 
                              Binding="{Binding MaterialPN}"
                              Width="160"/>
                <DataGridTextColumn Header="物料类型" 
                              Binding="{Binding MaterialType}"
                              Width="160"/>
                <!--<DataGridTextColumn Header="序号" 
                              Binding="{Binding materialorder}"
                              Width="140"/>-->
                <DataGridTextColumn Header="是否上传" 
                              Binding="{Binding IsUpload}"
                              Width="140"/>
                <DataGridTextColumn Header="时间"  
                              Binding="{Binding CreateDate, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                              Width="180"/>
                <DataGridTextColumn Header="数据采集组" 
                              Binding="{Binding GroupName}"
                              Width="*"/>
                </DataGrid.Columns>
        </DataGrid>


        <!-- 分页按钮 -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,10" Width="auto">
            <Button Content="首页" Command="{Binding FirstPageCommand}" Margin="5" Width="75" />
            <Button Content="上一页" Command="{Binding PrevPageCommand}" Margin="5" Width="75"/>
            <TextBlock Text="{Binding CurrentPage}" Margin="5"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="/" Margin="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TotalPages}" Margin="5"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Content="下一页" Command="{Binding NextPageCommand}" Margin="5" Width="75"/>
            <Button Content="尾页" Command="{Binding LastPageCommand}" Margin="5" Width="75"/>
        </StackPanel>
    </Grid>
</UserControl>
