<UserControl
    x:Class="MPAssmebleRecipe.Apps.Views.BlockManage.UcBlockAddView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:blockmanage="clr-namespace:MPAssmebleRecipe.Apps.ViewModels.BlockManage"
    xmlns:enum="clr-namespace:RogerTech.Common.Models;assembly=RogerTech.Common"
    xmlns:prism="http://prismlibrary.com/"
    Width="400"
    prism:ViewModelLocator.AutoWireViewModel="True">

    <!--  添加枚举资源  -->
    <UserControl.Resources>
        <ObjectDataProvider
            x:Key="ModuleColumnsEnum"
            MethodName="GetValues"
            ObjectType="{x:Type enum:ModuleColumns}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enum:ModuleColumns" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider
            x:Key="ModuleTypeEnum"
            MethodName="GetValues"
            ObjectType="{x:Type enum:ModuleType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enum:ModuleType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  标题  -->
        <!--<TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="{Binding Title}" FontSize="20" FontWeight="Bold" />-->

        <!--  Block名称  -->
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="Block名称：" />
        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding BlockName, UpdateSourceTrigger=PropertyChanged}" />
        <!--  Block料号  -->
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="BlockPn：" />
        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding BlockPn, UpdateSourceTrigger=PropertyChanged}" />

        <!--  AGV托盘号  -->
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="AGV托盘号：" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding BlockSequence, UpdateSourceTrigger=PropertyChanged}" />
        <!--  AGV上Block数量  -->
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="AGV上Block数量：" />
        <TextBox
            Grid.Row="3"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding BlockAmount, UpdateSourceTrigger=PropertyChanged}" />
        <!--  AGV上Block序号  -->
        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="AGV上Block序号：" />
        <TextBox
            Grid.Row="4"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding BlockIndex, UpdateSourceTrigger=PropertyChanged}" />

        <!--  Unit类型  -->
        <TextBlock
            Grid.Row="5"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="Unit类型：" />
        <ComboBox
            Grid.Row="5"
            Grid.Column="1"
            VerticalAlignment="Center"
            Cursor="Hand"
            ItemsSource="{Binding Source={StaticResource ModuleTypeEnum}}"
            SelectedItem="{Binding ModuleTypes}" />
        <!--  Unit数量  -->
        <TextBlock
            Grid.Row="6"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="Unit数量：" />
        <TextBox
            Grid.Row="6"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding ModuleAmount, UpdateSourceTrigger=PropertyChanged}" />
        <!--  Unit电芯数量  -->
        <TextBlock
            Grid.Row="7"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="Unit电芯数量：" />
        <TextBox
            Grid.Row="7"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding CellAmount, UpdateSourceTrigger=PropertyChanged}" />
        <!--  Pack层号  -->
        <TextBlock
            Grid.Row="8"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="Pack层号：" />
        <TextBox
            Grid.Row="8"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding LayerNum, UpdateSourceTrigger=PropertyChanged}" />
        <!--  归属拉线  -->
        <TextBlock
            Grid.Row="9"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="归属拉线：" />
        <TextBox
            Grid.Row="9"
            Grid.Column="1"
            VerticalAlignment="Center"
            Text="{Binding AttributionLine, UpdateSourceTrigger=PropertyChanged}" />

        <!--  极性  -->
        <TextBlock
            Grid.Row="10"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="极性：" />
        <StackPanel
            Grid.Row="10"
            Grid.Column="1"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <RadioButton
                x:Name="polarity"
                Margin="0,0,30,0"
                Content="正极"
                Cursor="Hand"
                IsChecked="{Binding Polarity, Mode=TwoWay}" />
            <RadioButton
                Content="负极"
                Cursor="Hand"
                IsChecked="True" />
        </StackPanel>
        <!--  限位片  -->
        <TextBlock
            Grid.Row="11"
            Grid.Column="0"
            VerticalAlignment="Center"
            Text="限位片：" />
        <StackPanel
            Grid.Row="11"
            Grid.Column="1"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <RadioButton
                x:Name="limitplate"
                Margin="0,0,42,0"
                Content="贴"
                Cursor="Hand"
                IsChecked="{Binding LimitPlate, Mode=TwoWay}" />
            <RadioButton
                Content="不贴"
                Cursor="Hand"
                IsChecked="True" />
        </StackPanel>

        <!--  按钮区域  -->
        <StackPanel
            Grid.Row="12"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,10"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="0,0,10,0"
                Command="{Binding CancelCommand}"
                Content="取消"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
            <Button
                Width="100"
                Command="{Binding ConfirmCommand}"
                Content="确定"
                Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </Grid>
</UserControl>