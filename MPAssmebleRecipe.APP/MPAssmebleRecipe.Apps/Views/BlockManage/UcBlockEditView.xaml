<UserControl
    x:Class="MPAssmebleRecipe.Apps.Views.BlockManage.UcBlockEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MPAssmebleRecipe.Apps.Views.BlockManage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="1000"
    Height="600"
    mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <Button
                Width="200"
                Margin="0,0,20,0"
                Command="{Binding SaveCommand}"
                Content="保存"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button
                Width="200"
                Margin="0,0,20,0"
                Command="{Binding CancelCommand}"
                Content="取消"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
        </StackPanel>
        <DataGrid
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            ItemsSource="{Binding BlockItems}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Binding="{Binding BlockName, Mode=TwoWay}"
                    Header="Block名称"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Binding="{Binding BlockPn, Mode=TwoWay}"
                    Header="Block料号"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Binding="{Binding BlockSequence, Mode=TwoWay}"
                    Header="AGV编号"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Binding="{Binding BlockAmount, Mode=TwoWay}"
                    Header="AGV上Block数量"
                    IsReadOnly="False" />
                <DataGridTextColumn
                    Binding="{Binding BlockIndex, Mode=TwoWay}"
                    Header="AGV上Block序号"
                    IsReadOnly="False" />
                <DataGridTextColumn
                    Binding="{Binding ModuleAmount, Mode=TwoWay}"
                    Header="Unit数量"
                    IsReadOnly="False" />
                <DataGridTextColumn
                    Binding="{Binding AttributionLine, Mode=TwoWay}"
                    Header="归属拉线"
                    IsReadOnly="False" />
                <DataGridTextColumn
                    Binding="{Binding LayerNum, Mode=TwoWay}"
                    Header="Pack层号"
                    IsReadOnly="False" />
                <!--<DataGridTextColumn
                    Binding="{Binding LineNum, Mode=TwoWay}"
                    Header="入箱料道号"
                    IsReadOnly="False" />-->
                <DataGridCheckBoxColumn
                    Binding="{Binding LimitPlate, Mode=TwoWay}"
                    Header="限位片"
                    IsReadOnly="False" />
                <!--<DataGridCheckBoxColumn
                    Binding="{Binding SplitType, Mode=TwoWay}"
                    Header="拆分类型"
                    IsReadOnly="False" />-->
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
