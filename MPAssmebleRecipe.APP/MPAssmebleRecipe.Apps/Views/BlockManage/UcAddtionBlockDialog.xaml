<UserControl
    x:Class="MPAssmebleRecipe.Apps.Views.BlockManage.UcAddtionBlockDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MPAssmebleRecipe.Apps.Views.BlockManage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="768"
    Height="600"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Style="{StaticResource MaterialDesignBody1TextBlock}"
            Text="补数设置" />
        <StackPanel
            Grid.Row="1"
            Margin="10,0,0,0"
            Orientation="Horizontal">
            <CheckBox
                Width="120"
                Content="堆叠工位1"
                IsChecked="{Binding Station1Select}" />
            <CheckBox
                Width="120"
                Content="堆叠工位2"
                IsChecked="{Binding Station2Select}" />
        </StackPanel>
        <DockPanel Grid.Row="2" Margin="10,0,0,0">
            <TextBlock
                Width="120"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Text="BLOCK组" />
            <ComboBox
                Width="160"
                ItemsSource="{Binding BlockGroups}"
                SelectedIndex="0"
                SelectedItem="{Binding SelectGroup}" />
            <Button
                Width="160"
                Margin="20,0,20,0"
                Command="{Binding DeleteCommand}"
                Content="删除"
                DockPanel.Dock="Right"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button
                Width="160"
                Margin="20,0,20,0"
                Command="{Binding AddCommand}"
                Content="添加"
                DockPanel.Dock="Right" />
        </DockPanel>
        <DataGrid
            Grid.Row="3"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="True"
            ItemsSource="{Binding BlocksGroupItem}"
            SelectedItem="{Binding SelectedBlockGroup}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="1*"
                    Binding="{Binding Name}"
                    Header="Block组名称" />
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding BlockItems[0].Pn}"
                    Header="BlockPn" />
                <DataGridTextColumn
                    Width="1*"
                    Binding="{Binding BlockItems.Count}"
                    Header="Block数量" />
                <DataGridTextColumn
                    Width="1*"
                    Binding="{Binding BlockItems[0].ModuleColumns}"
                    Header="模组列数" />
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                Command="{Binding SaveCommand}"
                Content="保存"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button
                Grid.Column="1"
                Content="取消"
                Style="{StaticResource MaterialDesignRaisedButton}" />
        </Grid>
    </Grid>
</UserControl>
