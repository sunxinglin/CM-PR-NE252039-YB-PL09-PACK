<UserControl x:Class="Automatic.Client.Views.Realtime.TerminalReshapeMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Automatic.Client.Common"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Automatic.Client.Views.Realtime"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="AliceBlue"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0"
                  md:ColorZoneAssist.Background="Black"
                  md:ColorZoneAssist.Foreground="White"
                  md:ColorZoneAssist.Mode="Custom">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="White" Text="通用状态" />
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0"
                            Height="40"
                            Orientation="Horizontal">
                    <common:LedSwitchCtrl x:Name="MESHeartBeatReq"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="MES心跳请求" />
                    <common:LedSwitchCtrl x:Name="PLCHeartBeatAck"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="PLC心跳应答" />
                    <common:LedSwitchCtrl x:Name="PLCHeartBeatReq"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="PLC心跳请求" />
                    <common:LedSwitchCtrl x:Name="MESHeartBeatAck"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="MES心跳应答" />
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <common:LedSwitchCtrl x:Name="AutoMode"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="自动模式" />
                    <common:LedSwitchCtrl x:Name="ManualMode"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="手动模式" />
                    <common:LedSwitchCtrl x:Name="StopMode"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="急停模式" />
                    <common:LedSwitchCtrl x:Name="Busy"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="繁忙" />
                    <common:LedSwitchCtrl x:Name="Idle"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="空闲" />
                </StackPanel>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1"
                  md:ColorZoneAssist.Background="Black"
                  md:ColorZoneAssist.Foreground="White"
                  md:ColorZoneAssist.Mode="Custom">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="White" Text="业务状态" />
                </StackPanel>
            </GroupBox.Header>

            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource MaterialDesignLabel}" TargetType="Label">
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width=" *" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width=" *" />
                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0" Header="AGV进工位">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="agvEnterReq"
                                                      OffColor="Gray"
                                                      OnColor="Orange"
                                                      Tip="AGV请求进" />
                                <Label Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Content="小车号" />
                                <TextBox x:Name="enterVectorCode"
                                         MinWidth="100"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                                <Label VerticalAlignment="Center" Content="Pack码" />
                                <TextBox x:Name="enterPackCode"
                                         MinWidth="200"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="agvEnterAck"
                                                      OffColor="Gray"
                                                      OnColor="Orange"
                                                      Tip="请求进确认" />
                                <common:LedSwitchCtrl x:Name="agvEnterOK"
                                                      OffColor="Gray"
                                                      OnColor="Green"
                                                      Tip="请求进OK" />
                                <Label VerticalAlignment="Center" Content="整形层级" />
                                <TextBox x:Name="enterReshapeLevel"
                                         MinWidth="50"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                                <common:LedSwitchCtrl x:Name="agvEnterNG"
                                                      OffColor="Gray"
                                                      OnColor="Red"
                                                      Tip="请求进NG" />
                                <Label VerticalAlignment="Center" Content="报错代码" />
                                <TextBox x:Name="enterErrorCode"
                                         MinWidth="50"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="开始整形">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="startReq"
                                                      OffColor="Gray"
                                                      OnColor="Orange"
                                                      Tip="开始请求" />
                                <Label Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Content="小车号" />
                                <TextBox x:Name="startAGVNo"
                                         MinWidth="100"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                                <Label VerticalAlignment="Center" Content="Pack码" />
                                <TextBox x:Name="startPackCode"
                                         MinWidth="200"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="startReqAck"
                                                      OffColor="Gray"
                                                      OnColor="Orange"
                                                      Tip="请求确认" />
                                <common:LedSwitchCtrl x:Name="startReqOK"
                                                      OffColor="Gray"
                                                      OnColor="Green"
                                                      Tip="请求OK" />
                                <Label Margin="50,0,0,0"
                                       VerticalAlignment="Center"
                                       Content="整形层级" />
                                <TextBox x:Name="startReshapeLevel"
                                         MinWidth="50"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                                <common:LedSwitchCtrl x:Name="startReqNG"
                                                      OffColor="Gray"
                                                      OnColor="Red"
                                                      Tip="请求NG" />
                                <Label Margin="50,0,0,0"
                                       VerticalAlignment="Center"
                                       Content="报错代码" />
                                <TextBox x:Name="startErrorCode"
                                         MinWidth="50"
                                         VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>

                <GroupBox Grid.Row="2"
                          Grid.Column="0"
                          Header="整形完成">
                    <Grid>
                        <Grid.Resources>
                            <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox">
                                <Setter Property="Margin" Value="2,0,16,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="40" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <common:LedSwitchCtrl x:Name="completeReq"
                                                  OffColor="Gray"
                                                  OnColor="Orange"
                                                  Tip="完成请求" />
                            <Label Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Content="小车号" />
                            <TextBox x:Name="completeAGVNo"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                            <Label VerticalAlignment="Center" Content="Pack码" />
                            <TextBox x:Name="completePackCode"
                                     MinWidth="150"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                            <Label VerticalAlignment="Center" Content="整形开始时间" />
                            <TextBox x:Name="glueStartTime"
                                     MinWidth="150"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <common:LedSwitchCtrl x:Name="completeAck"
                                                  OffColor="Gray"
                                                  OnColor="Green"
                                                  Tip="完成确认" />
                            <common:LedSwitchCtrl x:Name="completeOK"
                                                  OffColor="Gray"
                                                  OnColor="Green"
                                                  Tip="完成OK" />
                            <common:LedSwitchCtrl x:Name="completeNG"
                                                  OffColor="Gray"
                                                  OnColor="Red"
                                                  Tip="完成NG" />
                            <Label VerticalAlignment="Center" Content="报错代码" />
                            <TextBox x:Name="complateErrorCode"
                                     MinWidth="100"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                        </StackPanel>
                        <DataGrid x:Name="ReshapeData"
                                  Grid.Row="2"
                                  Width="1350"
                                  Height=" 400"
                                  Margin="0,15,0,0"
                                  HorizontalContentAlignment="Center"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding KeepDuration}"
                                                    Header="保压时间" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding PressureMax}"
                                                    Header="最大压力" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding PressureAverage}"
                                                    Header="平均压力" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding ShoudlerHeight}"
                                                    Header="肩部高度" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>




            </Grid>

        </GroupBox>
    </Grid>
</UserControl>
