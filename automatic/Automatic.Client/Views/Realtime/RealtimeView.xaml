<UserControl x:Class="Automatic.Client.Views.Realtime.RealtimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Automatic.Client.Views.Realtime"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="{DynamicResource MaterialDesignPaper}"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="5*" />
        </Grid.RowDefinitions>

        <TabControl x:Name="pageSelected"
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

            <TabItem x:Name="heatingFilmPressurize">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="加热膜加压" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:HeatingFilmPressurizeMonitorView x:Name="heatingFilmPressurizeMonitorView" />
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="lowerBoxGlue">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="下箱体涂胶" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:LowerBoxGlueMonitorView x:Name="lowerBoxGlueMonitorView" />
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="moduleInBox">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="模组入箱1" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:ModuleInBoxMonitorView x:Name="moduleInBoxMonitorView" />
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="moduleInBox2">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="模组入箱2" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:ModuleInBoxMonitorView x:Name="moduleInBox2MonitorView" />
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="moduleInBox3">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="模组入箱3" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:ModuleInBoxMonitorView x:Name="moduleInBox3MonitorView" />
                </ScrollViewer>
            </TabItem>

            <!--<TabItem x:Name="terminalReshape">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="极柱整形" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:TerminalReshapeMonitorView x:Name="terminalReshapeMonitorView" />
                </ScrollViewer>
            </TabItem>-->

            <!--<TabItem x:Name="moduleTighten">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="模组拧紧" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:ModuleTightenMonitorView x:Name="moduleTightenMonitorView" />
                </ScrollViewer>
            </TabItem>-->

            <TabItem x:Name="shoudlerGlue">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="肩部涂胶" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:ShoulderGlueMonitorView x:Name="shoulderGlueMonitorView" />
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="pressureStripPressurize">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="压条加压" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:PressureStripPressurizeMonitorView x:Name="pressureStripPressurizeMonitorView" />
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="upperCoverTighten">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="上盖拧紧1" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:UpperCoverTightenMonitorView x:Name="upperCoverTightenMonitorView" />
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="upperCoverTighten2">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="18" Text="上盖拧紧2" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <local:UpperCoverTightenMonitorView x:Name="upperCoverTighten2MonitorView" />
                </ScrollViewer>
            </TabItem>


        </TabControl>

        <!--  日志消息  -->
        <GroupBox Grid.Row="0"
                  Grid.RowSpan="2"
                  Grid.Column="1"
                  Margin="16,2,16,16"
                  materialDesign:ColorZoneAssist.Background="Black"
                  materialDesign:ColorZoneAssist.Foreground="White"
                  materialDesign:ColorZoneAssist.Mode="Custom"
                  Style="{DynamicResource MaterialDesignGroupBox}">
            <GroupBox.HeaderTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Width="40"
                                                 Height="40"
                                                 VerticalAlignment="Center"
                                                 Kind="Blog" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="28"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Text="日志消息" />
                    </StackPanel>
                </DataTemplate>
            </GroupBox.HeaderTemplate>
            <GroupBox.Resources>
                <Style TargetType="Label">
                    <Setter Property="FontSize" Value="20px" />
                    <Setter Property="FontFamily" Value="NSimSun" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Width" Value="120" />
                </Style>

                <Style TargetType="TextBlock">
                    <Setter Property="FontSize" Value="20px" />
                    <Setter Property="FontFamily" Value="NSimSun" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Width" Value="100" />
                </Style>
            </GroupBox.Resources>

            <local:UILogsView x:Name="uilogView" />
        </GroupBox>
    </Grid>
</UserControl>
