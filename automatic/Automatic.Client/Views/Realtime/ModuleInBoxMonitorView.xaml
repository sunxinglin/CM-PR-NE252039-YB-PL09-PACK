<UserControl x:Class="Automatic.Client.Views.Realtime.ModuleInBoxMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Automatic.Client.Common"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Automatic.Client.Views.Realtime"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Background="AliceBlue"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0"
                  md:ColorZoneAssist.Background="Black"
                  md:ColorZoneAssist.Foreground="White"
                  md:ColorZoneAssist.Mode="Custom">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="White" Text="通用状态" />
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Height="40"
                            Orientation="Horizontal">
                    <common:LedSwitchCtrl x:Name="MESHeartBeatReq"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="MES心跳请求" />
                    <common:LedSwitchCtrl x:Name="PLCHeartBeatAck"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="PLC心跳应答" />
                    <common:LedSwitchCtrl x:Name="PLCHeartBeatReq"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="PLC心跳请求" />
                    <common:LedSwitchCtrl x:Name="MESHeartBeatAck"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="MES心跳应答" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <common:LedSwitchCtrl x:Name="AutoMode"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="自动模式" />
                    <common:LedSwitchCtrl x:Name="ManualMode"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="手动模式" />
                    <common:LedSwitchCtrl x:Name="StopMode"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="急停模式" />
                    <common:LedSwitchCtrl x:Name="Busy"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="繁忙" />
                    <common:LedSwitchCtrl x:Name="Idle"
                                          OffColor="Gray"
                                          OnColor="Orange"
                                          Tip="空闲" />
                </StackPanel>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1"
                  md:ColorZoneAssist.Background="Black"
                  md:ColorZoneAssist.Foreground="White"
                  md:ColorZoneAssist.Mode="Custom">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="White" Text="业务状态" />
                </StackPanel>
            </GroupBox.Header>

            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource MaterialDesignLabel}" TargetType="Label">
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                    <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </Grid.Resources>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <GroupBox Grid.Column="0" Header="拍电芯码完成">
                    <StackPanel Height="40" Orientation="Horizontal">
                        <common:LedSwitchCtrl x:Name="reqTakePhotoComplete"
                                                  OffColor="Gray"
                                                  OnColor="Orange"
                                                  Tip="请求" />
                        <Label Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Content="电芯码" />
                        <TextBox x:Name="takePhotoCompleteCellCode"
                                     MinWidth="200"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                        <common:LedSwitchCtrl x:Name="ackTakePhotoComplete"
                                                   OffColor="Gray"
                                                   OnColor="Orange"
                                                   Tip="请求确认" />
                        <common:LedSwitchCtrl x:Name="takePhotoCompleteOK"
                                                   OffColor="Gray"
                                                   OnColor="Green"
                                                   Tip="OK" />
                        <Label Margin="10,0,0,0" Content="模组码" />
                        <TextBox x:Name="moduleCode"
                                      MinWidth="200"
                                      VerticalAlignment="Center"
                                      IsReadOnly="True"
                                      Text="" />
                        <common:LedSwitchCtrl x:Name="takePhotoCompleteNG"
                                                   Margin="10,0,0,0"
                                                   OffColor="Gray"
                                                   OnColor="Red"
                                                   Tip="NG" />
                        <Label Margin="10,0,0,0"
                                    Content="NG代码"
                                    Foreground="Red" />
                        <TextBox x:Name="photoNgCode"
                                      MinWidth="50"
                                      VerticalAlignment="Center"
                                      Foreground="Red"
                                      IsReadOnly="True"
                                      Text="" />
                    </StackPanel>
                </GroupBox>

                <Grid Grid.Row="1" Margin="0,10,0,0" >

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="10"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="AGV进工位">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="reqVectorEnter"
                                                  OffColor="Gray"
                                                  OnColor="Orange"
                                                  Tip="请求" />
                                <Label Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Content="小车号" />
                                <TextBox x:Name="vectorEnterNo"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                                <Label VerticalAlignment="Center" Content="Pack码" />
                                <TextBox x:Name="vectorEnterPackCode"
                                     MinWidth="200"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="ackVectorEnter"
                                                  OffColor="Gray"
                                                  OnColor="Orange"
                                                  Tip="请求确认" />
                                <common:LedSwitchCtrl x:Name="vectorEnterOK"
                                                  OffColor="Gray"
                                                  OnColor="Green"
                                                  Tip="OK" />
                                <Label VerticalAlignment="Center" Content="涂胶剩余时长" />
                                <TextBox x:Name="vectorEnterGlueRemainDuration"
                                     MinWidth="100"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                                <common:LedSwitchCtrl x:Name="vectorEnterNG"
                                                  Margin="10,0,0,0"
                                                  OffColor="Gray"
                                                  OnColor="Red"
                                                  Tip="NG" />
                                <Label Margin="10,0,0,0"
                                   Content="NG代码"
                                   Foreground="Red" />
                                <TextBox x:Name="vectorNgCode"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     Foreground="Red"
                                     IsReadOnly="True"
                                     Text="" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>


                    <GroupBox Grid.Column="2" Header="开始入箱">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="reqStart"
                                                  OffColor="Gray"
                                                  OnColor="Orange"
                                                  Tip="请求" />
                                <Label Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Content="小车号" />
                                <TextBox x:Name="startAGVNo"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                                <Label VerticalAlignment="Center" Content="Pack码" />
                                <TextBox x:Name="startPackCode"
                                     MinWidth="200"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <common:LedSwitchCtrl x:Name="ackStart"
                                                  OffColor="Gray"
                                                  OnColor="Orange"
                                                  Tip="请求确认" />
                                <common:LedSwitchCtrl x:Name="startOK"
                                                  OffColor="Gray"
                                                  OnColor="Green"
                                                  Tip="OK" />
                                <common:LedSwitchCtrl x:Name="startNG"
                                                  OffColor="Gray"
                                                  OnColor="Red"
                                                  Tip="NG" />
                                <Label Margin="10,0,0,0"
                                   Content="NG代码"
                                   Foreground="Red" />
                                <TextBox x:Name="startNgCode"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     Foreground="Red"
                                     IsReadOnly="True"
                                     Text="" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                </Grid>

                <GroupBox Grid.Row="2" Margin="0,10,0,0" Header="单模组入完成">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <common:LedSwitchCtrl x:Name="reqSingleInBoxComplete"
                                  OffColor="Gray"
                                  OnColor="Orange"
                                  Tip="请求" />
                            <Label Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Content="小车号" />
                            <TextBox x:Name="SingleInBoxCompleteAGVNo"
                                 MinWidth="50"
                                 VerticalAlignment="Center"
                                 IsReadOnly="True"
                                 Text="" />
                            <Label VerticalAlignment="Center" Content="Pack码" />
                            <TextBox x:Name="SingleInBoxCompletePackCode"
                                 MinWidth="200"
                                 VerticalAlignment="Center"
                                 IsReadOnly="True"
                                 Text="" />
                            <Label VerticalAlignment="Center" Content="模组码" />
                            <TextBox x:Name="SingleInBoxCompleteModuleCode"
                                MinWidth="200"
                                VerticalAlignment="Center"
                                IsReadOnly="True"
                                Text="" />
                            <Label VerticalAlignment="Center" Content="模组位置" />
                            <TextBox x:Name="SingleInBoxCompleteModuleLocation"
                                MinWidth="50"
                                VerticalAlignment="Center"
                                IsReadOnly="True"
                                Text="" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <common:LedSwitchCtrl x:Name="ackSingleInBoxComplete"
                                  OffColor="Gray"
                                  OnColor="Orange"
                                  Tip="请求确认" />
                            <common:LedSwitchCtrl x:Name="SingleInBoxCompleteOK"
                                  OffColor="Gray"
                                  OnColor="Green"
                                  Tip="OK" />
                            <common:LedSwitchCtrl x:Name="SingleInBoxCompleteNG"
                                  OffColor="Gray"
                                  OnColor="Red"
                                  Tip="NG" />
                            <Label Margin="10,0,0,0"
                                    Content="NG代码"
                                    Foreground="Red" />
                            <TextBox x:Name="SingleInBoxCompleteNgCode"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     Foreground="Red"
                                     IsReadOnly="True"
                                     Text="" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3"
                          Margin="0,10,0,0"
                          Header="入箱完成">
                    <Grid>
                        <Grid.Resources>
                            <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox">
                                <Setter Property="Margin" Value="2,0,16,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="40" />
                            <RowDefinition Height="230" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <common:LedSwitchCtrl x:Name="reqComplete"
                                                  OffColor="Gray"
                                                  OnColor="Orange"
                                                  Tip="请求" />
                            <Label Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Content="小车号" />
                            <TextBox x:Name="completeAGVNo"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                            <Label VerticalAlignment="Center" Content="Pack码" />
                            <TextBox x:Name="completePackCode"
                                     MinWidth="200"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Text="" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <common:LedSwitchCtrl x:Name="ackComplete"
                                                  OffColor="Gray"
                                                  OnColor="Green"
                                                  Tip="请求确认" />
                            <common:LedSwitchCtrl x:Name="completeOK"
                                                  OffColor="Gray"
                                                  OnColor="Green"
                                                  Tip="OK" />
                            <common:LedSwitchCtrl x:Name="completeNG"
                                                  OffColor="Gray"
                                                  OnColor="Red"
                                                  Tip="NG" />
                            <Label Margin="10,0,0,0"
                                   Content="NG代码"
                                   Foreground="Red" />
                            <TextBox x:Name="complateNgCode"
                                     MinWidth="50"
                                     VerticalAlignment="Center"
                                     Foreground="Red"
                                     IsReadOnly="True"
                                     Text="" />
                        </StackPanel>

                        <DataGrid x:Name="ModuleDatas"
                                  Grid.Row="2"
                                  Width="1350"
                                  Height="230"
                                  Margin="0,10,0,10"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding ModuleCode}"
                                                    Header="模组条码" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding PressurizeDuration}"
                                                    Header="保压时间" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding ModuleLenth}"
                                                    Header="模组长度" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding DownDistance}"
                                                    Header="下压距离" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding DownPressure}"
                                                    Header="下压压力" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding LeftPressure}"
                                                    Header="左侧压力" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding RightPressure}"
                                                    Header="右侧压力" />
                                <DataGridTextColumn Width="*"
                                                    Binding="{Binding CompleteTime}"
                                                    Header="完成时间" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

            </Grid>

        </GroupBox>
    </Grid>
</UserControl>
