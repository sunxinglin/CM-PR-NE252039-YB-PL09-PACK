                                <common:LedSwitchCtrl x:Name="inspectCompleteNG" Tip="首件NG" OnColor="Red" OffColor="Gray" ></common:LedSwitchCtrl>
                                <Label Content="报错代码" VerticalAlignment="Center"></Label>
                                <TextBox x:Name="inspectCompleteErrorCode" Text="" IsReadOnly="True" MinWidth="100" VerticalAlignment="Center"></TextBox>
                            </StackPanel>


                        </Grid>
                    </GroupBox>-->
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
