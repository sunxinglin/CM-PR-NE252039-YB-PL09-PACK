                </Grid.Background>
                <Image Width="200"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Source="/Resources/Logo/logo-bar_white.png" />
                <TextBlock x:Name="txtTitle"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="32px"
                           FontWeight="Bold"
                           Foreground="White" />
            </Grid>

