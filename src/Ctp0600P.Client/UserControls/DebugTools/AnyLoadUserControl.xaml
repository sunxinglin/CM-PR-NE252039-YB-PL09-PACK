<UserControl x:Class="Ctp0600P.Client.UserControls.DebugTools.AnyLoadUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ctp0600P.Client.UserControls.DebugTools"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:wcu="clr-namespace:AsZero.Wpf.Common.UserControls;assembly=AsZero.Wpf.Common"
             d:DataContext="{d:DesignInstance Type=local:AnyLoadUserControlVM}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
        </Grid>
        <GroupBox Grid.Row="0"
                  Grid.Column="0"
                  Margin="8"
                  md:ColorZoneAssist.Background="Black"
                  md:ColorZoneAssist.Foreground="White"
                  md:ColorZoneAssist.Mode="Custom"
                  FontSize="24"
                  Header="发送指令"
                  Style="{DynamicResource MaterialDesignGroupBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80" />
                    <RowDefinition Height="80" />
                    <RowDefinition Height="80" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Row="0"
                          Grid.ColumnSpan="3"
                          Width="256"
                          HorizontalAlignment="Left"
                          md:HintAssist.Hint="选择拧紧枪"
                          md:TextFieldAssist.HasClearButton="True"
                          DisplayMemberPath="Name"
                          ItemsSource="{Binding StationDesoutterList}"
                          SelectedItem="{Binding SelectedDesoutter}"
                          Style="{StaticResource MaterialDesignFilledComboBox}" />


                <Button Grid.Row="1"
                        Grid.Column="0"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0001}"
                        Content="MID0001" />
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0014}"
                        Content="MID0014" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0016}"
                        Content="MID0016" />
                <Button Grid.Row="1"
                        Grid.Column="3"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0018}"
                        Content="MID0018" />
                <Button Grid.Row="1"
                        Grid.Column="4"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0042}"
                        Content="MID0042" />
                <Button Grid.Row="1"
                        Grid.Column="5"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0043}"
                        Content="MID0043" />
                <Button Grid.Row="1"
                        Grid.Column="6"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0060}"
                        Content="MID0060" />
                <Button Grid.Row="1"
                        Grid.Column="7"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0062}"
                        Content="MID0062" />
                <Button Grid.Row="2"
                        Grid.Column="0"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0070}"
                        Content="MID0070" />
                <Button Grid.Row="2"
                        Grid.Column="1"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0082}"
                        Content="MID0082" />
                <Button Grid.Row="2"
                        Grid.Column="2"
                        Width="100"
                        Height="60"
                        HorizontalAlignment="Left"
                        Background="#e1bee7"
                        Command="{Binding MID0701}"
                        Content="MID0701" />

            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1"
                  Grid.Column="0"
                  Height="400"
                  Margin="0,5,5,5"
                  md:ColorZoneAssist.Background="Black"
                  md:ColorZoneAssist.Foreground="White"
                  md:ColorZoneAssist.Mode="Custom"
                  Style="{DynamicResource MaterialDesignGroupBox}">
            <GroupBox.HeaderTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Width="20"
                                     Height="20"
                                     VerticalAlignment="Center"
                                     Kind="TelevisionGuide" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="20"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Text="接收指令" />
                    </StackPanel>
                </DataTemplate>
            </GroupBox.HeaderTemplate>
            <ScrollViewer Grid.Row="3"
                          Grid.Column="1"
                          wcu:Helper.AutoScroll="{Binding IsMidsChanged}"
                          Background="Azure"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <wcu:LogMessageUserControl DataContext="{Binding Mids}" />
            </ScrollViewer>
        </GroupBox>

    </StackPanel>
</UserControl>

