<UserControl x:Class="Ctp0600P.Client.UserControls.DebugTools.ElectricScrewDriverUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ctp0600P.Client.UserControls.DebugTools"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance Type=local:ElectricScrewDriverUserControlVM}"
             d:DesignHeight="530"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="200" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Row="0"
                      Grid.Column="0"
                      Margin="8"
                      md:ColorZoneAssist.Background="Black"
                      md:ColorZoneAssist.Foreground="White"
                      md:ColorZoneAssist.Mode="Custom"
                      FontSize="16"
                      Header="发送指令"
                      Style="{DynamicResource MaterialDesignGroupBox}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Row="0"
                              Grid.ColumnSpan="3"
                              Width="150"
                              HorizontalAlignment="Left"
                              md:HintAssist.Hint="选择拧紧枪"
                              md:TextFieldAssist.HasClearButton="True"
                              DisplayMemberPath="DeviceNo"
                              ItemsSource="{Binding StationDesoutterList}"
                              SelectedItem="{Binding SelectedDesoutter}" />


                    <ComboBox Grid.Row="0"
                              Grid.Column="3"
                              Grid.ColumnSpan="3"
                              Width="150"
                              HorizontalAlignment="Left"
                              md:HintAssist.Hint="选择拧紧枪品牌"
                              md:TextFieldAssist.HasClearButton="True"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding DeviceBrandList}"
                              SelectedItem="{Binding SelectedBrand}" />

                    <TextBox Grid.Row="0"
                             Grid.Column="6"
                             HorizontalAlignment="Left"
                             md:HintAssist.Hint="程序号"
                             Text="{Binding Pset}" />


                    <Button Grid.Row="1"
                            Grid.Column="0"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding TightenGunEnabled}"
                            Content="使能" />

                    <!--<Button Grid.Row="1"
                            Grid.Column="0"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0001}"
                            Content="0001" />
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0014}"
                            Content="0014" />
                    <Button Grid.Row="1"
                            Grid.Column="2"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0016}"
                            Content="0016" />
                    <Button Grid.Row="1"
                            Grid.Column="3"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0018}"
                            Content="程序号" />
