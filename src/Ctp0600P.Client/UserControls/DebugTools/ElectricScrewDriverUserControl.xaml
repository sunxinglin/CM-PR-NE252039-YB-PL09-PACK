                            Grid.Column="7"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0062}"
                            Content="0062" />
                    <Button Grid.Row="2"
                            Grid.Column="0"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0070}"
                            Content="0070" />
                    <Button Grid.Row="2"
                            Grid.Column="1"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0082}"
                            Content="0082" />
                    <Button Grid.Row="2"
                            Grid.Column="2"
                            Width="70"
                            Height="30"
                            HorizontalAlignment="Left"
                            Background="#e1bee7"
                            Command="{Binding MID0701}"
                            Content="0701" />-->

