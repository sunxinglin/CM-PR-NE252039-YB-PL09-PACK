<UserControl x:Class="Ctp0600P.Client.UserControls.AlarmUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ctp0600P.Client.UserControls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <!--  and here's another  -->
        <ItemsControl MaxWidth="320"
                      MaxHeight="300"
                      Grid.IsSharedSizeScope="True"
                      ItemsSource="{Binding .}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!--  DataTemplate DataType="{x:Type domain:SelectableViewModel}">  -->
                    <Border x:Name="Border"
                            Padding="8"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,0,0,1">
                        <Grid Height="Auto" MaxWidth="320">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition SharedSizeGroup="Checkerz" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Button Width="60"
                                    Height="25"
                                    Padding="4,4,4,4"
                                    HorizontalContentAlignment="Center"
                                    Background="#CC3300"
                                    Content="{Binding CodeValue}"
                                    Style="{DynamicResource MaterialDesignRaisedButton}" />
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Text="{Binding Name}" />

                            <!--<ToggleButton VerticalAlignment="Center"
                                          Style="{StaticResource MaterialDesignActionLightToggleButton}" Content="{Binding Code}" />
                            -->
                            <!--<TextBlock Text="{Binding Code}" />-->
                            <StackPanel Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="8,5,0,0">
                                <TextBlock Width="270"
                                           Text="{Binding Description}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!--<DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource MaterialDesignSelection}" />
                        </DataTrigger>
                    </DataTemplate.Triggers>-->
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
