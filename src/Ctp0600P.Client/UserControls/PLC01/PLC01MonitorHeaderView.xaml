<UserControl x:Class="Ctp0600P.Client.UserControls.PLC01MonitorHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:auc="clr-namespace:AsZero.Wpf.Common.UserControls;assembly=AsZero.Wpf.Common"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ctp0600P.Client.UserControls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.8*" />
                <ColumnDefinition Width="1.8*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Label Content="工位PLC监控" />
                <!--<auc:LedSwitchCtrl IsChecked="{Binding DEV_HeartBeat_Req.Value}"
                                   OffColor="Gray"
                                   OnColor="Orange"
                                   Tip="" />-->
                <auc:LedSwitchCtrl IsChecked="{Binding MST_HeartBeat_Answer.Value}"
                                   OffColor="Gray"
                                   OnColor="Orange"
                                   Tip="" />
            </StackPanel>

            <auc:LedSwitchCtrl Grid.Column="1"
                               IsChecked="{Binding DEV_AutoMode.Value}"
                               OffColor="Gray"
                               OnColor="Green"
                               Tip="自动" />
            <auc:LedSwitchCtrl Grid.Column="2"
                               IsChecked="{Binding DEV_ManualMode.Value}"
                               OffColor="Gray"
                               OnColor="Orange"
                               Tip="手动" />
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <auc:LedSwitchCtrl Grid.Column="3"
                                   IsChecked="{Binding DEV_LetGo_Req.Value}"
                                   OffColor="Gray"
                                   OnColor="Green"
                                   Tip="放行" />
                <Label>|</Label>
                <auc:LedSwitchCtrl Grid.Column="3"
                                   IsChecked="{Binding MST_LetGo_Ack.Value}"
                                   OffColor="Gray"
                                   OnColor="Green"
                                   Tip="确认" />
            </StackPanel>

            <StackPanel Grid.Column="4" Orientation="Horizontal">
                <auc:LedSwitchCtrl Grid.Column="4"
                                   IsChecked="{Binding DEV_Reset_Req.Value}"
                                   OffColor="Gray"
                                   OnColor="Orange"
                                   Tip="复位" />
                <Label>|</Label>
                <auc:LedSwitchCtrl Grid.Column="3"
                                   IsChecked="{Binding MST_Reset_Ack.Value}"
                                   OffColor="Gray"
                                   OnColor="Green"
                                   Tip="确认" />
            </StackPanel>


            <auc:LedSwitchCtrl Grid.Column="5"
                               IsChecked="{Binding MST_Alarm.Value}"
                               OffColor="Gray"
                               OnColor="Red"
                               Tip="报警" />

            <auc:LedSwitchCtrl Grid.Column="6"
                              IsChecked="{Binding MST_OverrunAlarm.Value}"
                              OffColor="Gray"
                              OnColor="Red"
                              Tip="超时报警" />

        </Grid>

    </Grid>
</UserControl>
