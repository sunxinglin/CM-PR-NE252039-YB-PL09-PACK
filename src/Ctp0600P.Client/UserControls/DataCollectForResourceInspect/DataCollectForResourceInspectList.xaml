<UserControl x:Class="Ctp0600P.Client.UserControls.DataCollectForResourceInspect.DataCollectForResourceInspectList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ctp0600P.Client.UserControls.DataCollectForResourceInspect"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Name="listctrl">
    <Grid>
        <DataGrid ItemsSource="{Binding DataCollectForResourceInspectStations}" AutoGenerateColumns="False" CanUserReorderColumns="False" 
                  SelectedItem="{Binding SelectData}" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Width="200" Binding="{Binding Name}" IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="名称"/>
                    </DataGridTextColumn.Header>

                </DataGridTextColumn>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="操作"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="修改" Command="{Binding DataContext.ChangeDataCommand,ElementName=listctrl}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
