<UserControl x:Class="Ctp0600P.Client.UserControls.Leak"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ctp0600P.Client.UserControls"
             xmlns:auc="clr-namespace:AsZero.Wpf.Common.UserControls;assembly=AsZero.Wpf.Common"
             
             mc:Ignorable="d" 
            
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.Resources>
            <Style TargetType="auc:LedSwitchCtrl">
                <Setter Property="MaxHeight" Value="40"></Setter>
                <Setter Property="MinHeight" Value="20"></Setter>
                <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" ></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition  Height="30" ></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition ></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="15" Background="LightBlue">
            <TextBlock Text="MES  To PLC   信号点" FontSize="18" HorizontalAlignment="Left" FontWeight="Bold" Width="300"></TextBlock>
        </Grid>

        <Grid Grid.Row="1" Grid.ColumnSpan="15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition ></RowDefinition>
                <RowDefinition ></RowDefinition>
                <RowDefinition ></RowDefinition>
            </Grid.RowDefinitions>
            <auc:LedSwitchCtrl Tip="充气开始请求" IsChecked="{Binding 充气开始请求.Value}"  OnColor="Green" OffColor="Gray" MaxHeight="42" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"></auc:LedSwitchCtrl>
            <auc:LedSwitchCtrl Tip="充气完成确认" IsChecked="{Binding 充气完成确认.Value}"  OnColor="Green" OffColor="Gray" MaxHeight="42" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"></auc:LedSwitchCtrl>

            <Label Content="充气时长"  FontSize="15" Grid.Row="1" Grid.Column="0" VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 充气时长_MES.Value}"  FontSize="15" IsEnabled="False" IsReadOnly="True" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center"></TextBox>
            <Label Content="保压时长"  FontSize="15" Grid.Row="1"  Grid.Column="2" VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 保压时长_MES.Value}"  FontSize="15" IsEnabled="False" Grid.ColumnSpan="3" IsReadOnly="True" Grid.Row="1" Grid.Column="3" VerticalContentAlignment="Center"></TextBox>

            <Label Content="充气压力"  FontSize="15" Grid.Row="2" Grid.Column="0" VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 充气压力_MES.Value}"  FontSize="15" IsEnabled="False" IsReadOnly="True" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center"></TextBox>
            <Label Content="保压压力"  FontSize="15" Grid.Row="2" Grid.Column="2" VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 保压压力_MES.Value}"  FontSize="15" IsEnabled="False" IsReadOnly="True" Grid.Row="2" Grid.Column="3" VerticalContentAlignment="Center"></TextBox>
        </Grid>

        <Grid Grid.Row="2"  Grid.ColumnSpan="15" Background="AntiqueWhite">
            <TextBlock Text="PLC To MES   信号点"  FontSize="18" HorizontalAlignment="Left" FontWeight="Bold" Width="300"></TextBlock>
        </Grid>


        <Grid Grid.Row="3" Grid.ColumnSpan="15" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition ></RowDefinition>
                <RowDefinition ></RowDefinition>
                <RowDefinition ></RowDefinition>
                <RowDefinition ></RowDefinition>
            </Grid.RowDefinitions>

            <auc:LedSwitchCtrl Tip="开始充气" IsChecked="{Binding 开始充气.Value}"  OnColor="Green"  OffColor="Gray"  Grid.Row="0" Grid.Column="0"  Grid.ColumnSpan="2"></auc:LedSwitchCtrl>
            <auc:LedSwitchCtrl Tip="请求充气完成" IsChecked="{Binding 请求充气完成.Value}"  OnColor="Green" OffColor="Gray"  Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"></auc:LedSwitchCtrl>
            <auc:LedSwitchCtrl Tip="充气结果OK" IsChecked="{Binding 充气结果OK.Value}"  OnColor="Green" OffColor="Gray"  Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2"></auc:LedSwitchCtrl>
            <auc:LedSwitchCtrl Tip="充气结果NG" IsChecked="{Binding 充气结果NG.Value}"  OnColor="Red" OffColor="Gray"   Grid.Row="0" Grid.Column="6" Grid.ColumnSpan="2"></auc:LedSwitchCtrl>

            <Label HorizontalAlignment="Right" Content="充气开始时间"  FontSize="15" Grid.Row="1" Grid.Column="0"  VerticalContentAlignment="Center"></Label>
            <TextBox HorizontalAlignment="Left" Text="{Binding 充气开始时间.Value}"  FontSize="15" IsEnabled="False"  Grid.ColumnSpan="2"  IsReadOnly="True" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center"></TextBox>
            <Label HorizontalAlignment="Right" Content="充气结束时间"  FontSize="15" Grid.Row="1" Grid.Column="3"     VerticalContentAlignment="Center"></Label>
            <TextBox HorizontalAlignment="Left" Text="{Binding 充气结束时间.Value}"  FontSize="15" IsEnabled="False"  Grid.ColumnSpan="2"  IsReadOnly="True" Grid.Row="1" Grid.Column="4" VerticalContentAlignment="Center"></TextBox>
            <Label HorizontalAlignment="Left" Content="实时充气时间"  FontSize="15" Grid.Row="1" Grid.Column="6"     VerticalContentAlignment="Center" Grid.ColumnSpan="2" Width="100"></Label>
            <TextBox HorizontalAlignment="Left" Text="{Binding 实时充气时长.Value}" Foreground="Red"  FontSize="50" IsEnabled="False"  Grid.ColumnSpan="2"  IsReadOnly="True" Grid.Row="1" Grid.Column="8" VerticalContentAlignment="Center"></TextBox>

            <Label HorizontalAlignment="Right" Content="充气时长"  FontSize="15" Grid.Row="2" Grid.Column="0"  VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 充气时长.Value}"  FontSize="15" IsEnabled="False" IsReadOnly="True" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center"></TextBox>
            <Label HorizontalAlignment="Right" Content="保压时长"  FontSize="15" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"  VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 保压时长.Value}"  FontSize="15" IsEnabled="False" IsReadOnly="True" Grid.Row="2" Grid.Column="4" VerticalContentAlignment="Center"></TextBox>
            <Label HorizontalAlignment="Right" Content="充气压力"  FontSize="14" Grid.Row="2" Grid.Column="5" Grid.ColumnSpan="2"  VerticalContentAlignment="Center" ></Label>
            <TextBox Text="{Binding 充气压力.Value}"  FontSize="14" IsEnabled="False" IsReadOnly="True" Grid.Row="2" Grid.Column="7" VerticalContentAlignment="Center"></TextBox>
            <Label HorizontalAlignment="Right" Content="保压压力"  FontSize="14" Grid.Row="2" Grid.Column="8" Grid.ColumnSpan="2"  VerticalContentAlignment="Center" ></Label>
            <TextBox Text="{Binding 保压压力.Value}"  FontSize="14" IsEnabled="False" IsReadOnly="True" Grid.Row="2" Grid.Column="10" VerticalContentAlignment="Center"></TextBox>

            <Label HorizontalAlignment="Right" Content="总气压力"  FontSize="15" Grid.Row="3" Grid.Column="0"  VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 总气压力.Value}"  FontSize="15" IsEnabled="False" IsReadOnly="True" Grid.Row="3" Grid.Column="1" VerticalContentAlignment="Center"></TextBox>
            <Label HorizontalAlignment="Right" Content="比例阀当前压力"  FontSize="15" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"   VerticalContentAlignment="Center"></Label>
            <TextBox Text="{Binding 比例阀当前压力.Value}"  FontSize="15" IsEnabled="False" IsReadOnly="True" Grid.Row="3" Grid.Column="4" VerticalContentAlignment="Center"></TextBox>
            <Label HorizontalAlignment="Right" Content="亚德客当前压力"  FontSize="14" Grid.Row="3" Grid.Column="5"  Grid.ColumnSpan="2"  VerticalContentAlignment="Center" ></Label>
            <TextBox Text="{Binding 亚德客当前压力.Value}"  FontSize="14" IsEnabled="False" IsReadOnly="True" Grid.Row="3" Grid.Column="7" VerticalContentAlignment="Center"></TextBox>


        </Grid>

    </Grid>
</UserControl>