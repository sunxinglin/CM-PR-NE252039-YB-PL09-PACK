<Page x:Class="Ctp0600P.Client.Views.Pages.UseMgmtPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:viewmodels="clr-namespace:Ctp0600P.Client.ViewModels"
      Title="UseMgmtPage"
      d:DataContext="{d:DesignInstance Type=viewmodels:UserMgmtPageViewModel}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Background="{DynamicResource MaterialDesignPaper}"
      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
      mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <GroupBox Grid.Row="0"
                  Grid.Column="0"
                  Margin="16"
                  md:ColorZoneAssist.Background="Black"
                  md:ColorZoneAssist.Foreground="White"
                  md:ColorZoneAssist.Mode="Custom"
                  Style="{DynamicResource MaterialDesignGroupBox}">
            <GroupBox.HeaderTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Width="40"
                                     Height="40"
                                     VerticalAlignment="Center"
                                     Kind="TelevisionGuide" />
                        <TextBlock Margin="8,0,0,0"
                                   FontSize="28"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Text="用户操作" />
                    </StackPanel>
                </DataTemplate>
            </GroupBox.HeaderTemplate>
            <GroupBox.Resources>
                <Style TargetType="Label">
                    <Setter Property="FontSize" Value="20px" />
                    <Setter Property="FontFamily" Value="NSimSun" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Width" Value="120" />
                </Style>

                <Style TargetType="Button">
                    <Setter Property="FontSize" Value="20px" />
                    <Setter Property="FontFamily" Value="NSimSun" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="Bold" />
                </Style>
            </GroupBox.Resources>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Grid.Row="0"
                        Grid.Column="0"
                        Height="50"
                        Margin="40,10,40,10"
                        Background="Salmon"
                        Click="BtnClick_SwitchUser">
                    切换用户
                </Button>
                <Button Grid.Row="0"
                        Grid.Column="1"
                        Height="50"
                        Margin="40,10,40,10"
                        Background="OldLace"
                        Click="Button_SwitchUserToOperator">
                    注销(切换成操作员)
                </Button>
            </Grid>
        </GroupBox>

        <TabControl Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="16,0,16,10"
                    TabStripPlacement="Top">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid Name="Panel">
                                    <ContentPresenter x:Name="ContentSite"
                                                      Margin="10,2"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      ContentSource="Header" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Panel" Property="Background" Value="LightSkyBlue" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="False" />
                                            <Condition Property="IsEnabled" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <MultiTrigger.Setters>
                                            <Setter TargetName="Panel" Property="Background" Value="White" />
                                        </MultiTrigger.Setters>
                                    </MultiTrigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="False" />
                                            <Condition Property="IsEnabled" Value="False" />
                                        </MultiTrigger.Conditions>
                                        <MultiTrigger.Setters>
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Setter TargetName="Panel" Property="Background" Value="White" />
                                        </MultiTrigger.Setters>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!--  修改密码  -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Width="200"
                                Height="50"
                                Orientation="Horizontal">
                        <md:PackIcon Width="40"
                                     Height="50"
                                     VerticalAlignment="Center"
                                     Kind="PasswordReset" />
                        <TextBlock VerticalAlignment="Center" FontSize="24">修改密码</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <TabItem.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              DataContext="{Binding ChangeUserPasswordInput}">
                            <Grid.Resources>
                                <Style BasedOn="{StaticResource MaterialDesignLabel}" TargetType="Label">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="Margin" Value="80,0,0,0" />
                                    <Setter Property="FontSize" Value="24" />
                                </Style>
                                <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="Margin" Value="80,0,0,0" />
                                    <Setter Property="Width" Value="300" />
                                    <Setter Property="FontSize" Value="24" />
                                </Style>

                                <Style BasedOn="{StaticResource MaterialDesignPasswordBox}" TargetType="PasswordBox">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="Margin" Value="80,0,0,0" />
                                    <Setter Property="Width" Value="300" />
                                    <Setter Property="FontSize" Value="24" />
                                </Style>
                            </Grid.Resources>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                            </Grid.RowDefinitions>


                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Content="当前账号" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     IsEnabled="False"
                                     Text="{Binding Account}" />
                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Content="当前密码" />

                            <PasswordBox Name="OldPassword"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         md:TextFieldAssist.HasClearButton="True" />

                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Content="新密码" />

                            <PasswordBox Name="NewPassword"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         md:TextFieldAssist.HasClearButton="True" />

                            <Label Grid.Row="3"
                                   Grid.Column="0"
                                   Content="新密码(二次输入)" />

                            <PasswordBox Name="Confirm"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         md:TextFieldAssist.HasClearButton="True" />
                        </Grid>

                        <Button Grid.Row="1"
                                Grid.Column="0"
                                Width="200"
                                Height="50"
                                Margin="40,10,40,10"
                                HorizontalAlignment="Right"
                                Background="{StaticResource MaterialDesignLightForeground}"
                                Command="{Binding CmdResetChangeUserPasswordForm}"
                                Content="重置表单"
                                FontSize="24" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Width="200"
                                Height="50"
                                Margin="40,10,40,10"
                                HorizontalAlignment="Right"
                                Click="BtnClick_ChangeUserPassword"
                                Content="修改密码"
                                FontSize="24" />
                    </Grid>
                </TabItem.Content>
            </TabItem>

            <!--  创建用户  -->
            <TabItem IsEnabled="{Binding AppVM.CanAccessUserMgmt_MaintainUser.Value}">
                <TabItem.Header>
                    <StackPanel Width="200" Orientation="Horizontal">
                        <md:PackIcon Width="40"
                                     Height="50"
                                     VerticalAlignment="Center"
                                     Kind="UserAdd" />
                        <TextBlock VerticalAlignment="Center" FontSize="24">创建用户</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <TabItem.Content>

                    <Grid>
                        <Grid.Resources>
                            <Style BasedOn="{StaticResource MaterialDesignLabel}" TargetType="Label">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalAlignment" Value="Left" />
                                <Setter Property="Margin" Value="80,0,0,0" />
                                <Setter Property="FontSize" Value="24" />
                            </Style>
                            <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalAlignment" Value="Left" />
                                <Setter Property="Margin" Value="80,0,0,0" />
                                <Setter Property="Width" Value="300" />
                                <Setter Property="FontSize" Value="24" />
                            </Style>

                            <Style BasedOn="{StaticResource MaterialDesignPasswordBox}" TargetType="PasswordBox">
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalAlignment" Value="Left" />
                                <Setter Property="Margin" Value="80,0,0,0" />
                                <Setter Property="Width" Value="300" />
                                <Setter Property="FontSize" Value="24" />
                            </Style>
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190.5" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0"
                              Grid.Column="0"
                              Grid.ColumnSpan="2"
                              DataContext="{Binding CreateUserInput}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Content="账号名"
                                   FontSize="24" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Text="{Binding Account}" />

                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Content="密码" />

                            <PasswordBox Name="CreatePassword"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         md:TextFieldAssist.HasClearButton="True" />

                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Content="密码(二次确认)" />

                            <PasswordBox Name="CreatePassword2"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         md:TextFieldAssist.HasClearButton="True" />

                            <Label Grid.Row="3"
                                   Grid.Column="0"
                                   Content="姓名" />

                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Text="{Binding Name}" />

                        </Grid>

                        <Button Grid.Row="1"
                                Grid.Column="0"
                                Width="200"
                                Height="50"
                                Margin="40,10,40,10"
                                HorizontalAlignment="Center"
                                Background="{StaticResource MaterialDesignLightForeground}"
                                Command="{Binding CmdResetCreateUserForm}"
                                Content="重置表单"
                                FontSize="24" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Width="200"
                                Height="50"
                                Margin="40,10,40,10"
                                HorizontalAlignment="Center"
                                Click="BtnClick_CreateUser"
                                Content="创建用户"
                                FontSize="24" />
                    </Grid>

                </TabItem.Content>
            </TabItem>

            <!--  管理Claim  -->
            <TabItem IsEnabled="{Binding AppVM.CanAccessUserMgmt_Privilege.Value}">
                <TabItem.Header>
                    <StackPanel Width="200" Orientation="Horizontal">
                        <md:PackIcon Width="40"
                                     Height="50"
                                     VerticalAlignment="Center"
                                     Kind="ZodiacVirgo" />
                        <TextBlock VerticalAlignment="Center" FontSize="24">管理权限</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <TabItem.Content>
                    <Grid>
                        <ListView ItemsSource="{Binding Resources}" TextElement.FontSize="14">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Id">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Id}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="名称">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ShortName}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="Auto" Header="权限">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding ClaimsAllowed}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Claim.Value, Mode=OneWay}" IsChecked="{Binding Checked}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Margin="4,0,4,0"
                                                        Command="{Binding CmdUpdateResource}"
                                                        CommandParameter="{Binding .}"
                                                        Content="更新" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </TabItem.Content>
            </TabItem>


        </TabControl>

    </Grid>
</Page>
