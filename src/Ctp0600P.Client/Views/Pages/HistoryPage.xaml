<Page x:Class="Ctp0600P.Client.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      Title="HistoryPage"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Background="{DynamicResource MaterialDesignPaper}"
      Loaded="Page_Loaded"
      mc:Ignorable="d">
    <Page.Resources />
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="50" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Text="开始时间" />
            <DatePicker Grid.Row="0"
                        Grid.Column="1"
                        Width="100"
                        Height="40"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Language="zh-cn"
                        SelectedDate="{Binding Date_Begin, StringFormat=yyyy-MM-dd, Mode=TwoWay}"
                        Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
            <materialDesign:TimePicker Grid.Column="2"
                                       Width="100"
                                       Height="40"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       HorizontalContentAlignment="Center"
                                       Language="zh-cn"
                                       SelectedTime="{Binding Time_Begin, StringFormat=mm:ss, Mode=TwoWay}" />

            <TextBlock Grid.Column="3"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Text="结束时间" />
            <DatePicker Grid.Row="0"
                        Grid.Column="4"
                        Width="100"
                        Height="40"
                        HorizontalAlignment="Right"
                        SelectedDate="{Binding Date_End, StringFormat=yyyy-MM-dd}"
                        Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
            <materialDesign:TimePicker Grid.Column="5"
                                       Width="100"
                                       Height="40"
                                       HorizontalAlignment="Left"
                                       HorizontalContentAlignment="Center"
                                       Language="zh-cn"
                                       SelectedTime="{Binding Time_End, StringFormat=mm:ss, Mode=TwoWay}" />

            <Button Grid.Row="0"
                    Grid.Column="6"
                    Width="150"
                    Height="40"
                    Margin="50,0,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding SearchHisData}"
                    Content="查询" />
        </Grid>
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="18"
                       Text="产量：" />
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="DarkOrange"
                       Text="{Binding PCount}" />
        </Grid>
        <StackPanel Grid.Row="2"
                    Width="Auto"
                    VerticalAlignment="Stretch">
            <ListView Width="Auto"
                      Height="500"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      ItemsSource="{Binding ProductList}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="350"
                                        DisplayMemberBinding="{Binding PackCode}"
                                        Header="Pack码" />
                        <GridViewColumn Width="240"
                                        DisplayMemberBinding="{Binding CreateTime}"
                                        Header="进站时间" />
                        <GridViewColumn Width="120"
                                        DisplayMemberBinding="{Binding Status}"
                                        Header="当前状态" />
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
