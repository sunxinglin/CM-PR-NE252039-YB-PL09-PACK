<Window x:Class="Ctp0600P.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vms="clr-namespace:Ctp0600P.Client.ViewModels"
        d:DataContext="{d:DesignInstance Type=vms:AppViewModel}"
        Closed="Window_Closed"
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" />
    </WindowChrome.WindowChrome>
    <Window.Title>
        <MultiBinding StringFormat="{}{0} ({1})">
            <Binding Source="{StaticResource AppName}" />
            <Binding Path="AppVersion.Value" />
        </MultiBinding>
    </Window.Title>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="bool2Vis" />
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Name="main"
               Background="#F9F9F9"
               LastChildFill="True">
        <!-- 顶部状态栏 -->
        <StackPanel DockPanel.Dock="Top">
            <Grid Height="80">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.Background>
                        <SolidColorBrush Color="#3f51b5" />
                    </Grid.Background>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/Resources/Images/CATL.jpg" />
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Click="ToggleMenu_Click"
                                Foreground="White"
                                VerticalAlignment="Center">
                            <md:PackIcon Kind="Menu" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Click="Home_Click"
                                Foreground="White"
                                VerticalAlignment="Center"
                                ToolTip="生产管理">
                            <md:PackIcon Kind="Home" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.Background>
                        <SolidColorBrush Color="#3f51b5" />
                    </Grid.Background>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="400" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="32px"
                               FontWeight="Bold"
                               Foreground="White"
                               IsHitTestVisible="False"
                               Text="{Binding StationTitle.Value}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignIconButton}" Click="Minimize_Click"
                                Foreground="White" ToolTip="最小化" WindowChrome.IsHitTestVisibleInChrome="True">
                            <md:PackIcon Kind="WindowMinimize" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconButton}" Click="Close_Click"
                                Foreground="White" ToolTip="关闭" WindowChrome.IsHitTestVisibleInChrome="True">
                            <md:PackIcon Kind="Close" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </StackPanel>

        <!-- 底部状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Height="35" Background="#3f51b5" Foreground="White" FontSize="14">
            <StatusBarItem HorizontalAlignment="Left" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="IP:" />
                    <TextBlock Text="{Binding IPAddress.Value}" />
                    <TextBlock Text=" |  版本:" />
                    <TextBlock Text="{Binding AppVersion.Value}" />
                    <TextBlock Text=" |  服务器:" />
                    <Button Background="LawnGreen"
                            Content="{md:PackIcon Heart}"
                            IsEnabled="{Binding HubConnected.Value}"
                            ToolTip="Icon"
                            Height="20" Width="20" Padding="0" Margin="0" VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="操作者:" />
                    <TextBlock Text="{Binding UserName.Value}" />
                    <TextBlock Text=" |  权限:" />
                    <TextBlock Text="{Binding ClaimValue.Value}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- 左侧导航菜单 -->
        <md:DrawerHost x:Name="MainDrawer">
            <md:DrawerHost.LeftDrawerContent>
                <DockPanel Width="180">
                    <ListBox>
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Height" Value="45" />
                            </Style>
                            <Style TargetType="md:PackIcon">
                                <Setter Property="Width" Value="25" />
                                <Setter Property="Height" Value="25" />
                                <Setter Property="Margin" Value="20 0 5 0" />
                            </Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="15" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </ListBox.Resources>
                        <ListBoxItem PreviewMouseLeftButtonUp="MenuClick_ParamsMgmt">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Wrench" />
                                <TextBlock Text="参数设置" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem PreviewMouseLeftButtonUp="MenuClick_Realtime">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccessPointNetwork" />
                                <TextBlock Text="生产管理" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem PreviewMouseLeftButtonUp="MenuClick_History">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="History" />
                                <TextBlock Text="生产记录" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem PreviewMouseLeftButtonUp="MenuClick_DebugTools">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Bug" />
                                <TextBlock Text="调试工具" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem PreviewMouseLeftButtonUp="MenuClick_UserMgmt"
                                     IsEnabled="{Binding CanAccessUserMgmt.Value}"
                                     Visibility="Hidden">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Account" />
                                <TextBlock Text="用户管理" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </md:DrawerHost.LeftDrawerContent>
            
            <!-- 具体任务区域 -->
            <Frame Name="navWin"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   HorizontalContentAlignment="Stretch"
                   VerticalContentAlignment="Stretch"
                   Background="#FF1E3853"
                   NavigationUIVisibility="Hidden"
                   ScrollViewer.HorizontalScrollBarVisibility="Visible"
                   ScrollViewer.VerticalScrollBarVisibility="Visible" />
        </md:DrawerHost>
    </DockPanel>
</Window>