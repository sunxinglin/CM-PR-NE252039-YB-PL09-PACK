<Window x:Class="Ctp0600P.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{StaticResource AppName}" 
        Height="400" Width="500" 
        WindowStyle="None" 
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen" 
        MouseLeftButtonDown="MoveWindow_MouseLeftButtonDown"
        FontFamily="Segoe UI Emoji">
    <Border BorderThickness="1,1,1,1" >
        <Border.BorderBrush>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF796EE6" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Rectangle Height="280" VerticalAlignment="Top" Grid.Row="0">
                <Rectangle.Fill>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF2281D1"/>
                        <GradientStop Color="#FF34268A" Offset="1"/>
                        <GradientStop Color="#FF33288B" Offset="0.546"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Height="100" Width="350" >
                <!--<Viewbox VerticalAlignment="Top" HorizontalAlignment="Left" Width="100" >
                    <Image Source="/Resources/Logo/logo-bar_white.png" ></Image>
                </Viewbox>-->
                <TextBlock Text="{StaticResource AppName}"  Style="{StaticResource MaterialDesignHeadline3TextBlock}"  VerticalAlignment="Center"
                           HorizontalAlignment="Center" Foreground="Gainsboro" />
            </Grid>


            <Grid Grid.Row="1">
                <Label Visibility="Collapsed" Content="请刷卡登录" FontSize="48" />
                <TabControl
                  Style="{StaticResource MaterialDesignNavigatilRailTabControl}"
                  materialDesign:ColorZoneAssist.Mode="Standard"
                  materialDesign:ShadowAssist.ShadowDepth="Depth0">
                    <TabItem Visibility="Collapsed">
                        <!--<TabItem.Header >
                            <StackPanel Height="auto" Width="auto">
                                <materialDesign:PackIcon Kind="BarcodeScan" Width="40" Height="50" HorizontalAlignment="Center" />
                                <TextBlock Text="刷卡登录" HorizontalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>-->
                        <Grid FocusManager.FocusedElement="{Binding ElementName=CardNo}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="70"/>
                                <RowDefinition Height="80"/>
                                <RowDefinition Height="70"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                          
                            <PasswordBox Grid.Row="1" Grid.Column="1" Name="CardNo"
                                  materialDesign:HintAssist.Hint=""
                                  materialDesign:TextFieldAssist.TextBoxViewMargin="1 0 1 0"
                                  materialDesign:HintAssist.FloatingScale="0.80"
                                  Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                  FontSize="24" PasswordChanged="CardNo_PasswordChanged" >
                                <PasswordBox.InputBindings>
                                    <KeyBinding  Key="Enter" Command="{Binding LoginCmd}" CommandParameter="{Binding ElementName=CardNo}" />
                                </PasswordBox.InputBindings>
                            </PasswordBox>
                            <Label Grid.Row="1" Grid.Column="1" Content="CATL ID CARD"  FontSize="30"  HorizontalAlignment="Center" VerticalAlignment="Center" Width="380" Height="100" Background="White" />
                            <Button Content="取消" Name="close" FontSize="20" MinWidth="200" MinHeight="50" Click="BtnCancel_Click" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="2"/>
                        </Grid>
                    </TabItem>
                    <!--<TabItem>
                        <TabItem.Header>
                            <StackPanel Height="auto" Width="auto">
                                <materialDesign:PackIcon  Kind="Keyboard" Width="40" Height="50" HorizontalAlignment="Center" />
                                <TextBlock Text="密码登录" HorizontalAlignment="Center" />
                            </StackPanel>
                        </TabItem.Header>
                        <Grid FocusManager.FocusedElement="{Binding ElementName=pswdbox}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="60"/>
                                <RowDefinition Height="60"/>
                                <RowDefinition Height="100"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Row="0" Grid.Column="1"
                        Height="60" Width="50" 
                        Kind="Account" VerticalAlignment="Center" Grid.ColumnSpan="2" />
                            <TextBox x:Name="Account" Grid.Row="0" Grid.Column="2" 
                        materialDesign:HintAssist.Hint="账号" 
                        materialDesign:HintAssist.Foreground="Green"
                        materialDesign:TextFieldAssist.UnderlineBrush="Coral"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        FontSize="20"
                        Text="{Binding Account}">
                            </TextBox>
                            <materialDesign:PackIcon Grid.Row="1" Grid.Column="1"
                        Height="60" Width="50"
                        Kind="Lock" VerticalAlignment="Bottom"/>

                            <PasswordBox Grid.Row="1" Grid.Column="2"
                        x:Name="pswdbox"
                        materialDesign:HintAssist.Hint="密码"
                        materialDesign:HintAssist.Foreground="Green"
                        materialDesign:TextFieldAssist.UnderlineBrush="Coral"
                        Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" FontSize="20"/>

                            <StackPanel Grid.Row="2" Grid.Column="1"  Grid.ColumnSpan="2" Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignRaisedDarkButton}" Width="120" Height="40" ToolTip="Resource name: MaterialDesignRaisedAccentButton"
                                        HorizontalAlignment="Left" VerticalAlignment="Center" IsDefault="True" Command="{Binding CmdValidateUser}"
                                        CommandParameter="{Binding ElementName=pswdbox}" Margin="30,30,0,30">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="SignIn" VerticalAlignment="Center" HorizontalAlignment="Left" Width="40"></materialDesign:PackIcon>
                                        <TextBlock>登录</TextBlock>
                                    </StackPanel>
                                </Button>

                                <Button Background="MistyRose" Foreground="SeaGreen" Width="120" Height="40" ToolTip="Resource name: MaterialDesignRaisedAccentButton"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" IsCancel="True" Click="BtnCancel_Click" Margin="40,30,0,30">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="UserCancel" VerticalAlignment="Center" HorizontalAlignment="Left" Width="40"></materialDesign:PackIcon>
                                        <TextBlock>取消</TextBlock>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                        </Grid>
                    </TabItem>-->
                </TabControl>


            </Grid>

            <Grid Grid.Row="2" Height="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width ="100" />
                    <ColumnDefinition Width ="80" />
                    <ColumnDefinition Width ="180" />
                    <ColumnDefinition Width ="70" />
                    <ColumnDefinition Width ="50" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource MaterialDesignBody1TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Copyright：" />
                <TextBlock Grid.Column="1" Style="{StaticResource MaterialDesignBody1TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{StaticResource Manufacturer}" />
                <TextBlock Grid.Column="3" Style="{StaticResource MaterialDesignBody1TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Version:" />
                <TextBlock Grid.Column="4" Style="{StaticResource MaterialDesignBody1TextBlock}" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{StaticResource AppVersion}" />
            </Grid>


        </Grid>
    </Border>
</Window>