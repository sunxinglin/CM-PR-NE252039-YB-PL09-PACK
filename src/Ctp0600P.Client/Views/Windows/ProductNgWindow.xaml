<Window x:Class="Ctp0600P.Client.Views.Windows.ProductNgWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ctp0600P.Client.Views.Windows"
        WindowStartupLocation="CenterScreen"
        WindowState ="Normal"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:ProductNGViewModel}" Name="win"
        Title="产品NG" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition  Width="3*"/>
            </Grid.ColumnDefinitions>
            <Label Content="产品条码" Grid.Column="0" FontSize="40" VerticalContentAlignment="Center"/>
            <Label Content="{Binding Code}"  Grid.Column="1"  FontSize="40" VerticalContentAlignment="Center"/>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Content="确定" Grid.Column="0" FontSize="20" VerticalContentAlignment="Center" HorizontalAlignment="Center" MinWidth="200" MinHeight="50" Command="{Binding Sumbit}" CommandParameter="{Binding ElementName=win}"/>
            <Button Content="取消" Grid.Column="1" FontSize="20" VerticalContentAlignment="Center" HorizontalAlignment="Center" MinWidth="200" MinHeight="50" Name="exit" Click="exit_Click"/>
        </Grid>
    </Grid>
</Window>
