<UserControl x:Class="Ctp0600P.Client.Views.ParamConfigPages.ScanCodeGunConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:validations="clr-namespace:Ctp0600P.Client.Validations"
             xmlns:viewmodels="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ScanCodeGunConfigPageVM}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="DefaultComboBoxStyle"
               BasedOn="{x:Null}"
               TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="40" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderBrush" Value="#FFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button x:Name="ComList"
                Width="140"
                Height="45"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{Binding Add}"
                Content="添加"
                Tag="{Binding ComList}" />
        <Button Grid.Column="1"
                Width="140"
                Height="45"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{Binding Del}"
                Content="删除" />
        <Button x:Name="BaudRateList"
                Grid.Column="2"
                Width="140"
                Height="45"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{Binding Save}"
                Content="提交"
                Tag="{Binding BaudRateList}" />

        <ListBox Grid.Row="1"
                 Grid.ColumnSpan="4"
                 ItemContainerStyle="{StaticResource ListItemNullFocusContainerStyle}"
                 ItemsSource="{Binding Path=StationScanCodeGunList}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  Margin="15,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  FontSize="18"
                                  IsChecked="{Binding IsSelected}" />

                        <Border Grid.Column="1"
                                Margin="5"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="LightBlue" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Border.Style>
                            <Grid Margin="15,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="70" />
                                    <RowDefinition Height="70" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <!--  是否启用  -->
                                    <ColumnDefinition Width="75" />
                                    <!--  串口号  -->
                                    <ColumnDefinition Width="90" />
                                    <!--  串口号下拉框  -->
                                    <ColumnDefinition Width="*" />
                                    <!--  波特率  -->
                                    <ColumnDefinition Width="90" />
                                    <!--  波特率下拉框  -->
                                    <ColumnDefinition Width="*" />
                                    <!--  备注  -->
                                    <ColumnDefinition Width="90" />
                                    <!--  备注文本框  -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          Margin="15,0,0,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Content="启用"
                                          FlowDirection="RightToLeft"
                                          FontSize="18"
                                          IsChecked="{Binding IsEnable}" />
                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="串口：" />

                                <ComboBox Grid.Column="2"
                                          HorizontalAlignment="Left"
                                          DisplayMemberPath="PortName"
                                          FontSize="18"
                                          ItemsSource="{Binding ElementName=ComList, Path=Tag}"
                                          SelectedValue="{Binding Port, Mode=TwoWay}"
                                          SelectedValuePath="PortName"
                                          Style="{StaticResource DefaultComboBoxStyle}" />
                                <TextBlock Grid.Column="3"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="波特率：" />
                                <ComboBox Grid.Column="4"
                                          HorizontalAlignment="Left"
                                          DisplayMemberPath="BaudRate"
                                          FontSize="18"
                                          ItemsSource="{Binding ElementName=BaudRateList, Path=Tag}"
                                          SelectedValue="{Binding Baud, Mode=TwoWay}"
                                          SelectedValuePath="BaudRate"
                                          Style="{StaticResource DefaultComboBoxStyle}" />
                                <TextBlock Grid.Column="5"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="设备号：" />
                                <TextBox Grid.Column="6"
                                         Height="40"
                                         Margin="0,0,10,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         FontSize="20"
                                         Style="{DynamicResource ValidationTextBoxStyle}"
                                         ToolTip="请输入正确的设备号">
                                    <TextBox.Text>
                                        <Binding Mode="TwoWay"
                                                 NotifyOnValidationError="True"
                                                 Path="DeviceNo"
                                                 UpdateSourceTrigger="PropertyChanged">
                                            <Binding.ValidationRules>
                                                <validations:PositiveIntegerRule ValidatesOnTargetUpdated="True" />
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="备注：" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="6"
                                         Height="40"
                                         Margin="0,0,10,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         FontSize="20"
                                         Text="{Binding Remark}">
                                    <TextBox.Resources>
                                        <VisualBrush x:Key="HintText"
                                                     AlignmentX="Left"
                                                     Opacity="0.5"
                                                     Stretch="None"
                                                     TileMode="None">
                                            <VisualBrush.Visual>
                                                <TextBlock FontSize="15"
                                                           FontStyle="Italic"
                                                           Text="备注信息" />
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="{x:Null}">
                                                    <Setter Property="Background" Value="{StaticResource HintText}" />
                                                </Trigger>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource HintText}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                            </Grid>
                        </Border>
                    </Grid>

                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>