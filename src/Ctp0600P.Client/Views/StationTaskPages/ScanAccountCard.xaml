<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.ScanAccountCard"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:UserControls="clr-namespace:Ctp0600P.Client.UserCtrls"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:viewmodels="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels"
                             Title="ScanCode"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Background="#0000"
                             Loaded="StationTaskCommonPage_Loaded"
                             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="账号：" />
        <TextBox Name="tbTagValue"
                 Grid.Row="0"
                 Grid.Column="1"
                 Width="270"
                 Height="50"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 VerticalContentAlignment="Center"
                 FontSize="20"
                 IsReadOnly="True"
                 Text="{Binding AccountCardValue}">

            <TextBox.Resources>
                <VisualBrush x:Key="HintText"
                             AlignmentX="Left"
                             Opacity="0.5"
                             Stretch="None"
                             TileMode="None">
                    <VisualBrush.Visual>
                        <TextBlock FontStyle="Italic" Text="请扫描员工条码" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </TextBox.Resources>
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter Property="Background" Value="{StaticResource HintText}" />
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background" Value="{StaticResource HintText}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>


        <!--<TextBox Name="tbTagValue" Text="{Binding AccountCardValue}" IsReadOnly="False" Grid.Column="1" Grid.Row="0" VerticalContentAlignment="Center" VerticalAlignment="Bottom" HorizontalAlignment="Left" FontSize="20"  Width="270" Height="50">

            <TextBox.Resources>
                <VisualBrush x:Key="HintText" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left">
                    <VisualBrush.Visual>
                        <TextBlock FontStyle="Italic" Text="请扫描员工条码"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </TextBox.Resources>
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter Property="Background" Value="{StaticResource HintText}"/>
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background" Value="{StaticResource HintText}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
            <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding ScanIDCard}"></KeyBinding>
            </TextBox.InputBindings>
        </TextBox>-->


        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="用户名：" />
        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="{Binding AccountName}" />

    </Grid>
</local:StationTaskCommonPage>
