<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.ScanCollect"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Background="#0000"
                             Loaded="StationTaskCommonPage_Loaded"
                             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
                             mc:Ignorable="d">

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding PageScale.Value}" ScaleY="{Binding PageScale.Value}" />
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="80" />
            <RowDefinition Height="80" />
            <RowDefinition Height="50" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.ColumnSpan="5"
              Margin="50,50,0,0"
              DataContext="{Binding Path=TaskScanCollect}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Grid.ColumnSpan="2"
                       Margin="20,0,0,0"
                       FontSize="30"
                       Foreground="Red"
                       Text="{Binding ScanCollectName}" />

            <TextBlock Grid.Column="4"
                       Grid.ColumnSpan="2"
                       Height="Auto"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="30"
                       Text="{Binding Status}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="FontSize" Value="26" />
                        <Style.Triggers>
                            <Trigger Property="Text" Value="已完成">
                                <Setter Property="Foreground" Value="DarkGreen" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>

            </TextBlock>
        </Grid>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="5"
                    Orientation="Horizontal">
            <TextBlock Margin="100,0,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="25"
                       Text="条码规则：" />

            <TextBlock Name="tbRuleValue"
                       Grid.ColumnSpan="4"
                       Width="Auto"
                       Height="Auto"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Background="#0000"
                       FontSize="25"
                       FontStretch="Medium"
                       Text="{Binding Path=TaskScanCollect.CodeRule}" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="5"
                    Orientation="Horizontal">
            <TextBlock Margin="100,0,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="25"
                       Text="条码内容：" />
            <TextBox Name="tbTagValue"
                     Grid.ColumnSpan="4"
                     Width="Auto"
                     Height="Auto"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Background="#0000"
                     BorderThickness="0,0,0,1"
                     FontSize="25"
                     FontStretch="Medium"
                     IsReadOnly="True"
                     Text="{Binding ScanData}" />

        </StackPanel>




    </Grid>
</local:StationTaskCommonPage>
