<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.ScanCode"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:model="clr-namespace:Yee.Common.Library.CommonEnum;assembly=Yee.Common.Library"
                             xmlns:viewmodels="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels"
                             Title="ScanCode"
                             d:DataContext="{d:DesignInstance Type=viewmodels:ScanCodeViewModel}"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Background="#0000"
                             Loaded="StationTaskCommonPage_Loaded"
                             mc:Ignorable="d">
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding PageScale.Value}" ScaleY="{Binding PageScale.Value}" />
        </Grid.LayoutTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

            </Grid>
            <ListBox Grid.Row="1"
                     Margin="0"
                     HorizontalContentAlignment="Stretch"
                     VerticalContentAlignment="Top"
                     ItemContainerStyle="{StaticResource ListItemNullFocusContainerStyle}"
                     ItemsSource="{Binding Path=StationTaskBomList}"
                     MouseDown="ListBox_MouseDown"
                     SelectionChanged="ListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                MouseDown="ListBox_MouseDown">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="LightBlue" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Border.Style>
                            <Grid Margin="15,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45" />
                                    <RowDefinition Height="45" />
                                    <RowDefinition Height="45" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="180*" />
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="40*" />
                                    <ColumnDefinition Width="80*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding GoodsName}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="物料PN：" />
                                <TextBlock Grid.Column="2"
                                           MinWidth="120"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding GoodsPN}" />
                                <TextBlock Grid.Column="3"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="用量：" />
                                <TextBlock Grid.Column="4"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding UseNum}" />

                                <Grid Grid.Row="1"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Label HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Content="内部码规则:"
                                               FontSize="18" />
                                        <TextBlock MinWidth="120"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Foreground="Blue"
                                                   Text="{Binding GoodsPNRex}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.精追}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.批追}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.扫库存}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Label HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Content="外部码规则:"
                                               FontSize="18" />
                                        <TextBlock MinWidth="120"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Foreground="Blue"
                                                   Text="{Binding OuterGoodsPNRex}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="2"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.扫库存}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.批追}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.精追}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Label HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Content="库存码:"
                                               FontSize="18" />
                                        <TextBlock MinWidth="120"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Foreground="Blue"
                                                   Text="{Binding UniBarCode, Mode=TwoWay, NotifyOnSourceUpdated=True}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.扫库存}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.批追}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.精追}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Label HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Content="批次码:"
                                               FontSize="18" />
                                        <TextBlock MinWidth="120"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Foreground="Blue"
                                                   Text="{Binding BatchBarCode, Mode=TwoWay, NotifyOnSourceUpdated=True}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.扫库存}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.批追}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TracingType}" Value="{x:Static model:TracingTypeEnum.精追}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Label HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Content="外部码:"
                                               FontSize="18" />
                                        <TextBlock MinWidth="120"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Foreground="Blue"
                                                   Text="{Binding GoodsOuterCode, Mode=TwoWay, NotifyOnSourceUpdated=True}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Grid.RowSpan="3"
                                           Grid.Column="5"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="{Binding Status}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="FontSize" Value="22" />
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="已完成">
                                                    <Setter Property="Foreground" Value="DarkGreen" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</local:StationTaskCommonPage>
