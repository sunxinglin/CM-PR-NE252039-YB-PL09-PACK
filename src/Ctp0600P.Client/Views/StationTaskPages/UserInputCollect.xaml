<local:StationTaskCommonPage  x:Class="Ctp0600P.Client.Views.StationTaskPages.UserInputCollect"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="#0000" Loaded="StationTaskCommonPage_Loaded"
   >

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="10"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="260"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"></ColumnDefinition>
            <ColumnDefinition Width="80"></ColumnDefinition>
            <ColumnDefinition Width="2*"></ColumnDefinition>
            <ColumnDefinition Width="100"></ColumnDefinition>
            <ColumnDefinition Width="80"></ColumnDefinition>
            <ColumnDefinition Width="100"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!--<Button  Grid.Column="1" Width="100" Content="获取重量" Click="Btn_Test" Margin="100 0 0 0"></Button>-->

        <TextBlock Text="{Binding TaskUserScan.UserScanName}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" FontSize="24" Margin="20,10,0,0"/>
        <TextBlock Text="最小值：" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right"  FontSize="20"  />
        <TextBlock Text="{Binding MinData}" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20"  />

        <TextBox  IsReadOnly="True" Height="50" VerticalContentAlignment="Center"  VerticalAlignment="Center" TextAlignment="Center" Foreground="Green" Grid.Row="1" Grid.Column="2"  Text="{Binding UserInput}" FontSize="26">
            <TextBox.Resources>
                <VisualBrush x:Key="HintText" TileMode="None" Opacity="0.5" Stretch="None" AlignmentX="Left">
                    <VisualBrush.Visual>
                        <TextBlock FontStyle="Italic" Text="请按小键盘输入数值"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </TextBox.Resources>
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter Property="Background" Value="{StaticResource HintText}"/>
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background" Value="{StaticResource HintText}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>
        <TextBlock Text="最大值：" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right"  FontSize="20" />
        <TextBlock Text="{Binding MaxData}" Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20" />


        <TextBlock Grid.Row="1" Grid.Column="5"  Text="{Binding TaskUserScan.Status}"  VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="Black"></Setter>
                    <Setter Property="FontSize" Value="26"></Setter>
                    <Style.Triggers>
                        <Trigger Property="Text" Value="已完成">
                            <Setter Property="Foreground" Value="DarkGreen"></Setter>
                            <Setter Property="FontWeight" Value="Bold"></Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>


        <TextBlock Visibility="{Binding NgTips}"  Grid.Row="3" Grid.Column="1" FontSize="24" Grid.ColumnSpan="3"  Foreground="Red" Text="NG 输入值必须在合理范围内！"  VerticalAlignment="Center" HorizontalAlignment="Center">
           
        </TextBlock>


        <Grid Grid.Row="4"  Grid.Column="1" Grid.ColumnSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="2" Grid.Column="0" Content="1" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="2" Grid.Column="1" Content="2" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="2" Grid.Column="2" Content="3" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="1" Grid.Column="0" Content="4" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="1" Grid.Column="1" Content="5" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="1" Grid.Column="2" Content="6" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="0" Grid.Column="0" Content="7" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="0" Grid.Column="1" Content="8" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="0" Grid.Column="2" Content="9" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="0" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="3" Grid.Column="2" Content="." FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="0" Grid.Column="3" Content="清除" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="1" Grid.Column="3"   Content="退格" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
                <Button Style="{Binding defaultBtnStyle}"  Grid.Row="2" Grid.RowSpan="2"  Grid.Column="3" Content="确定" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            </Grid>
        </Grid>


    </Grid>
</local:StationTaskCommonPage>
