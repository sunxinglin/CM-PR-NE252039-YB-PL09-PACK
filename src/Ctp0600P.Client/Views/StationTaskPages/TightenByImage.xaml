<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.TightenByImage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
      xmlns:vm="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels"
      xmlns:uc="clr-namespace:Ctp0600P.Client.UserControls.ScrewView"
      d:DataContext="{d:DesignInstance Type=vm:TightenByImageViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Loaded="StationTaskCommonPage_Loaded"
      Title="TightenByImage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="45"/>

        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Label Content="当前序号：" FontSize="20" Foreground="Red"/>
            <Label Content="{Binding ScrewNo.Value}" FontSize="20" Foreground="Orange" Width=" 100"/>
        </StackPanel>

        <ItemsControl Width="{Binding Canva_Width.Value}" Height="{Binding Canva_Height.Value}" ItemsSource="{Binding ScrewLayout.Value}" Grid.Row="1">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas x:Name="testImage">
                        <Canvas.Background>
                            <ImageBrush ImageSource="{Binding ImageSource.Value}">
                                <ImageBrush.Stretch>Fill</ImageBrush.Stretch>
                            </ImageBrush>
                        </Canvas.Background>
                    </Canvas>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <uc:ScrewView  VerticalAlignment="Top"  Margin="{Binding MarginLayout}"   HorizontalAlignment="Left" OrderNo="{Binding OrderNo}" Status="{Binding Status.Value}"  Width ="20" Height = "20" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>


        <StackPanel Orientation="Horizontal" Grid.Row="2" VerticalAlignment="Center">
            <Label Content="扭力：" FontSize="15"/>
            <Label Content="{Binding Torque.Value}" FontSize="15" Width="80"/>
            <Label Content="角度：" FontSize="15"/>
            <Label Content="{Binding Angle.Value}" FontSize="15" Width="80"/>
            <!-- <Button Content="正反转切换" Width="110" Command="{Binding ChangeReverse}"/> -->
            <Label Content="当前程序号：" FontSize="15"/>
            <Label Content="{Binding CurProgram.Value}" FontSize="15" Width="80"/>
        </StackPanel>
    </Grid>
</local:StationTaskCommonPage>
