<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.BoltGun"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             Title="ScanCode"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Background="#0000"
                             Loaded="StationTaskCommonPage_Loaded"
                             MouseDown="ListBox_MouseDown"
                             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
                             mc:Ignorable="d">

    <Grid MouseDown="ListBox_MouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="0" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--<Button x:Name="ssssss" Width="100" Content="测试" Click="Btn_Test" Margin="0 0 200 0"></Button>
        <Button Width="100" Content="测试" Click="Btn_Test2" Margin="100 0 0 0"></Button>-->

        <ListBox Grid.Row="1"
                 Margin="0"
                 HorizontalContentAlignment="Stretch"
                 VerticalContentAlignment="Top"
                 ItemContainerStyle="{StaticResource ListItemNullFocusContainerStyle}"
                 ItemsSource="{Binding Path=StationTaskScrewList}"
                 MouseDown="ListBox_MouseDown"
                 SelectionChanged="ListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            MouseDown="ListBox_MouseDown">
                        <!--<i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDown">
                                <i:InvokeCommandAction Command="{Binding Path=DataContext.YourClickCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type YourControl}}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>-->
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="LightBlue" />
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="CornerRadius" Value="3" />
                            </Style>
                        </Border.Style>
                        <Grid Margin="15,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="45" />
                                <RowDefinition Height="45" />
                                <RowDefinition Height="45" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="4"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Text="{Binding ScrewSpecs}" />
                            <TextBlock Grid.Row="1"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Text="程序号：" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       MinWidth="120"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Text="{Binding ProgramNo}" />

                            <TextBlock Name="TogglePopupButton"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Cursor="Hand"
                                       FontSize="18"
                                       Foreground="Blue"
                                       PreviewMouseLeftButtonDown="TextBlock_PreviewMouseLeftButtonDown"
                                       Text="安装进度：" 
                                       Tag="{Binding ProgramNo}"/>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="3"
                                        Orientation="Horizontal">
                                <TextBlock HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding CurNo}" />
                                <TextBlock HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="/" />
                                <TextBlock HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding UseNum}" />
                            </StackPanel>

                            <TextBlock Grid.RowSpan="2"
                                       Grid.Column="6"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding Status}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="FontSize" Value="26" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="已完成">
                                                <Setter Property="Foreground" Value="DarkGreen" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Grid.Row="2" Grid.ColumnSpan="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60*" />
                                    <ColumnDefinition Width="50*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100*" />
                                    <ColumnDefinition Width="100*" />
                                    <ColumnDefinition Width="100*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           MinWidth="120"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding CurScrewValueStr}" />
                                <TextBlock Grid.Column="1"
                                           MinWidth="120"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding CurScrewState}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black" />
                                            <Setter Property="FontSize" Value="26" />
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="OK">
                                                    <Setter Property="Foreground" Value="DarkGreen" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </Trigger>
                                                <Trigger Property="Text" Value="NG">
                                                    <Setter Property="Foreground" Value="Red" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="3"
                                           MinWidth="120"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding CurFinalAngleStr}" />
                                <TextBlock Grid.Column="4"
                                           MinWidth="120"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding CurAngle_MinStr}" />
                                <TextBlock Grid.Column="5"
                                           MinWidth="120"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding CurAngle_MaxStr}" />

                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</local:StationTaskCommonPage>
