<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.LeakPage"
      xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:viewmodels="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels" 
      xmlns:UserControls="clr-namespace:Ctp0600P.Client.UserCtrls"
      xmlns:rwc="clr-namespace:Ctp0600P.Client.UserControls"
             xmlns:auc="clr-namespace:AsZero.Wpf.Common.UserControls;assembly=AsZero.Wpf.Common"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Background="{DynamicResource MaterialDesignPaper}"
                             Loaded="StationTaskCommonPage_Loaded"
      Title="ScanCode">
    <Grid>
        <Grid.Resources>
            <Style TargetType="auc:LedSwitchCtrl">
                <Setter Property="MaxHeight" Value="40"></Setter>
                <Setter Property="MinHeight" Value="20"></Setter>
                <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="1"  Background="LightGreen">
            <TextBlock Text="通用实时状态" FontSize="18" HorizontalAlignment="Left" FontWeight="Bold" Width="300"></TextBlock>
        </Grid>

        <rwc:PlcGeneralCtrl Grid.Column="1" Grid.Row="1" DataContext="{Binding LeakPlcGeneralVM.Value}"></rwc:PlcGeneralCtrl>
        <rwc:Leak  Grid.Column="1" Grid.Row="2" Grid.RowSpan="4" DataContext="{Binding LeakCoreVM.Value}" ></rwc:Leak>
        <Grid Grid.Row="7" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="180"></ColumnDefinition>
                <ColumnDefinition Width="180"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Name="reLeak" Content="重新充气" HorizontalAlignment="Center" Width="150" Height="45" Command="{Binding ReLeak}" Cursor="Hand"/>
            <Button Grid.Column="2" Name="completeConfirm" Content="充气完成确认" HorizontalAlignment="Center" Width="150" Height="45" Command="{Binding CompleteConfirm}" Cursor="Hand"/>

        </Grid>
    </Grid>
</local:StationTaskCommonPage>