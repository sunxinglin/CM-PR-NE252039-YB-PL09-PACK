<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.RecordTimeTaskPage"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:vm="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels"
                             Title="RecordTimeTaskPage"
                             d:DataContext="{d:DesignInstance Type=vm:RecordTimeViewModel}"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Background="#0000"
                             Loaded="StationTaskCommonPage_Loaded"
                             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1"
                    Grid.ColumnSpan="2"
                    Margin="0,50,0,0"
                    Orientation="Vertical">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="50" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           HorizontalAlignment="Right"
                           FontSize="25"
                           Text="任务名称:" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Margin="10,0,0,0"
                           FontSize="25"
                           Text="{Binding TaskName.Value}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           HorizontalAlignment="Right"
                           FontSize="20"
                           Text="时间:" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Margin="10,0,0,0"
                           FontSize="20"
                           Text="{Binding RecordTime.Value}" />
            </Grid>
        </StackPanel>

    </Grid>
</local:StationTaskCommonPage>
