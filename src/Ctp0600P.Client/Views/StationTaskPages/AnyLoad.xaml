<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.AnyLoad"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Background="#0000"
                             Loaded="StationTaskCommonPage_Loaded"
                             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
                             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--<Button  Grid.Column="1" Width="100" Content="获取重量" Click="Btn_Test" Margin="100 0 0 0"></Button>-->

        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="26"
                   Text="重量：" />
        <TextBox Name="tbTagValue"
                 Grid.Row="1"
                 Grid.Column="1"
                 Width="270"
                 Height="50"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 VerticalContentAlignment="Center"
                 FontSize="26"
                 IsReadOnly="True"
                 Text="{Binding WeightData}">
            <TextBox.Resources>
                <VisualBrush x:Key="HintText"
                             AlignmentX="Left"
                             Opacity="0.5"
                             Stretch="None"
                             TileMode="None">
                    <VisualBrush.Visual>
                        <TextBlock FontStyle="Italic" Text="获取电子秤读数" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </TextBox.Resources>
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter Property="Background" Value="{StaticResource HintText}" />
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background" Value="{StaticResource HintText}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <TextBlock Grid.Row="2"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="26"
                   Text="上限：" />
        <TextBlock Grid.Row="2"
                   Grid.Column="1"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="26"
                   Text="{Binding MaxWeightData}" />
        <TextBlock Grid.Row="3"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="26"
                   Text="下限：" />
        <TextBlock Grid.Row="3"
                   Grid.Column="1"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="26"
                   Text="{Binding MinWeightData}" />

        <!--<TextBox Text="{Binding MaxWeightData}" IsReadOnly="True" Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" VerticalAlignment="Bottom" HorizontalAlignment="Left" FontSize="20"  Width="270" Height="50">

        </TextBox>-->

        <Button Grid.Row="4"
                Grid.Column="2"
                Width="200"
                Height="50"
                HorizontalAlignment="Left"
                VerticalContentAlignment="Center"
                Command="{Binding AnyLoadConfirm}"
                FontSize="26">
            确认
        </Button>
    </Grid>
</local:StationTaskCommonPage>
