<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.LetGoPage"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:auc="clr-namespace:AsZero.Wpf.Common.UserControls;assembly=AsZero.Wpf.Common"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             Title="ScanCode"
                             d:DataContext="{d:DesignInstance Type=local:LetGoPage}"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Loaded="StationTaskCommonPage_Loaded"
                             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>
        <!--<Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Text="1、组织构建上传Catl_MES数据包" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Left">
            </TextBlock>
            <ProgressBar Name="progressBar_Step2" Grid.Row="1" Height="30" Width="500" HorizontalAlignment="Left" Margin="35 0 0 0" Style="{Binding demoStyle}"></ProgressBar>

            <TextBlock Grid.Row="2" Text="2、按放行按钮" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Left">
            </TextBlock>

            <TextBlock Grid.Row="3" Text="3、上传数据包到CATL MES" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Left">
            </TextBlock>
            <ProgressBar Name="progressBar_Step3" Grid.Row="4" Height="30" Width="500" HorizontalAlignment="Left" Margin="35 0 0 0" Style="{Binding demoStyle}"></ProgressBar>
        </Grid>-->

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <auc:LedSwitchCtrl Height="80"
                                   FontSize="25"
                                   IsChecked="{Binding HasUpMesOK.Value, Mode=TwoWay}"
                                   OffColor="Gray"
                                   OnColor="Green"
                                   Tip="上传MES完成" />
                <Button Width="150"
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding ReUploadMes}"
                        Content="重新上传"
                        FontSize="25" />
                <Button Width="150"
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding SetComplate}"
                        Content="手动完成"
                        FontSize="25" />
            </StackPanel>
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock FontSize="30"
                           Foreground="{Binding TipColor.Value}"
                           Text="Tips:" />
                <TextBlock FontSize="30"
                           Foreground="{Binding TipColor.Value}"
                           Text="{Binding Tips.Value}" />
            </StackPanel>
        </Grid>
    </Grid>
</local:StationTaskCommonPage>
