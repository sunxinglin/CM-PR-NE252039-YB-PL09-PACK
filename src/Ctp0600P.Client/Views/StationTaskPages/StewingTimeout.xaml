<local:StationTaskCommonPage x:Class="Ctp0600P.Client.Views.StationTaskPages.StewingTimeout"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:UserControls="clr-namespace:Ctp0600P.Client.UserCtrls"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:local="clr-namespace:Ctp0600P.Client.Views.StationTaskPages"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:viewmodels="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels"
                             Title="ScanCode"
                             d:DesignHeight="450"
                             d:DesignWidth="800"
                             Background="#0000"
                             Loaded="StationTaskCommonPage_Loaded"
                             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="90" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="{Binding StepCode}" />
        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="完工时间：" />
        <TextBox Name="tbTagValue"
                 Grid.Row="0"
                 Grid.Column="2"
                 Width="270"
                 Height="50"
                 HorizontalAlignment="Left"
                 VerticalContentAlignment="Center"
                 FontSize="20"
                 IsReadOnly="True"
                 Text="{Binding StewingStartTime}" />
        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="{Binding TimeName}" />
        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="当前时间：" />

        <TextBox Grid.Row="1"
                 Grid.Column="2"
                 Width="270"
                 Height="50"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 FontSize="20"
                 IsReadOnly="True"
                 Text="{Binding NowTime}" />
        <TextBlock Grid.Row="4"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="校验状态：" />
        <TextBlock Grid.Row="4"
                   Grid.Column="2"
                   MinWidth="120"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="{Binding Pass}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="FontSize" Value="26" />
                    <Style.Triggers>
                        <Trigger Property="Text" Value="通过">
                            <Setter Property="Foreground" Value="DarkGreen" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                        <Trigger Property="Text" Value="不通过">
                            <Setter Property="Foreground" Value="Red" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="管控时长：" />
        <TextBox Grid.Row="2"
                 Grid.Column="2"
                 Width="270"
                 Height="50"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 FontSize="20"
                 IsReadOnly="True"
                 Text="{Binding AllowTime}" />
        <TextBlock Grid.Row="3"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Text="实际时长：" />
        <TextBox Grid.Row="3"
                 Grid.Column="2"
                 Width="270"
                 Height="50"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Center"
                 FontSize="20"
                 IsReadOnly="True"
                 Text="{Binding RealTime}" />
    </Grid>
</local:StationTaskCommonPage>
