<Window x:Class="Ctp0600P.Client.Views.Windows.CheckPowerPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Ctp0600P.Client.Views.Windows"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Ctp0600P.Client.ViewModels"
        Name="win"
        Title="权限验证"
        Width="500"
        Height="250"
        d:DataContext="{d:DesignInstance Type=vm:CheckPowerViewModel}"
        Loaded="win_Loaded"
        MouseLeftButtonDown="win_MouseLeftButtonDown"
        ResizeMode="NoResize"
        ShowActivated="False"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50*" />
                <RowDefinition Height="90*" />
                <RowDefinition Height="80*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
            </Grid.ColumnDefinitions>
            <PasswordBox Name="CardNo"
                         Grid.Row="1"
                         Grid.Column="1"
                         materialDesign:HintAssist.FloatingScale="0.80"
                         materialDesign:HintAssist.Hint="CATL ID CARD"
                         materialDesign:TextFieldAssist.TextBoxViewMargin="1 0 1 0"
                         Cursor="Arrow"
                         FontSize="25"
                         PasswordChanged="CardNo_PasswordChanged"
                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}">
                <PasswordBox.InputBindings>
                    <KeyBinding Key="Enter"
                                Command="{Binding Check}"
                                CommandParameter="{Binding ElementName=CardNo}" />


                </PasswordBox.InputBindings>
            </PasswordBox>
            <Label Grid.Row="1"
                   Grid.Column="1"
                   Width="380"
                   Height="100"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Background="White"
                   Content="CATL ID CARD"
                   FontSize="30" />
            <TextBlock Grid.Row="2"
                       Grid.ColumnSpan="3"
                       Padding="1,1,1,1"
                       HorizontalAlignment="Center"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="Red"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />
            <Button Name="close"
                    Grid.Row="2"
                    Grid.Column="1"
                    MinWidth="200"
                    MinHeight="50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Click="close_Click"
                    Content="取消"
                    FontSize="20" />
        </Grid>
    </Grid>
</Window>
