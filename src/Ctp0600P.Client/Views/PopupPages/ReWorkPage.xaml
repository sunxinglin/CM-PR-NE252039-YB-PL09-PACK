<Window x:Class="Ctp0600P.Client.Views.StationTaskPages.ReWorkPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:Yee.Common.Library.CommonEnum;assembly=Yee.Common.Library"
        xmlns:vm="clr-namespace:Ctp0600P.Client.ViewModels"
        Title="{Binding PageTitle}"
        Width="850"
        Height="650"
        d:DataContext="{d:DesignInstance Type=vm:ReWorkPageViewModel}"
        d:DesignHeight="450"
        d:DesignWidth="800"
        Background="{DynamicResource MaterialDesignPaper}"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="CheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="False" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource CheckBoxFocusVisual}" />
            <Setter Property="Height" Value="52" />
            <Setter Property="IsChecked" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Width="{TemplateBinding Height}" Height="{TemplateBinding Height}">
                                <Rectangle x:Name="CheckBoxRectangle"
                                           Fill="White"
                                           Opacity="0.3"
                                           RadiusX="5"
                                           RadiusY="5" />
                                <Rectangle x:Name="CheckBoxRectangleOut"
                                           RadiusX="5"
                                           RadiusY="5"
                                           Stroke="#FFABADB3"
                                           StrokeThickness="1" />
                                <Grid x:Name="CheckedMark"
                                      Width="{TemplateBinding Height}"
                                      Height="{TemplateBinding Height}"
                                      Visibility="Collapsed">
                                    <Viewbox>
                                        <Grid>
                                            <Path Data="M1,9 L10,17"
                                                  SnapsToDevicePixels="True"
                                                  Stroke="#3553ad"
                                                  StrokeThickness="3" />
                                            <Path Data="M8,17 L20,4"
                                                  SnapsToDevicePixels="True"
                                                  Stroke="#3553ad"
                                                  StrokeThickness="3" />
                                        </Grid>
                                    </Viewbox>
                                </Grid>
                            </Grid>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckedMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>



    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="200*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!--<TextBlock Foreground="OrangeRed" FontSize="14" Margin="10 0 0 0" Text="Tip：可将已完成任务设置为未完成，也可将未完成任务设置为已完成"></TextBlock>-->

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="10,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="Blue"
                           Text="Pack码：" />
                <TextBlock Margin="10,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="Black"
                           Text="{Binding PackCode.Value}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Margin="10,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="Blue"
                           Text="工位：" />
                <TextBlock Margin="10,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="Black"
                           Text="{Binding StepCode.Value}" />
            </StackPanel>
        </Grid>
        <ListBox Grid.Row="1"
                 Margin="0"
                 HorizontalContentAlignment="Stretch"
                 VerticalContentAlignment="Top"
                 ItemContainerStyle="{StaticResource ListItemNullFocusContainerStyle}"
                 ItemsSource="{Binding ReWorkDatas.Value}"
                 ScrollViewer.CanContentScroll="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Height="auto"
                            Margin="5"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="LightBlue" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="CornerRadius" Value="2" />
                            </Style>
                        </Border.Style>
                        <Grid Margin="15,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="BlueViolet"
                                       Text="{Binding WorkName}" />
                            <TextBlock Grid.Column="2"
                                       MinWidth="120"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Text="{Binding Statue, Mode=TwoWay}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="FontSize" Value="26" />
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="已完成">
                                                <Setter Property="Foreground" Value="DarkGreen" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </Trigger>
                                            <Trigger Property="Text" Value="未完成">
                                                <Setter Property="Foreground" Value="Red" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Grid.Column="3"
                                    Click="Button_Click_1"
                                    Content="设置未完工" />
                            <ListBox Grid.Row="1"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="4"
                                     Margin="10,0,0,0"
                                     HorizontalContentAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     ItemContainerStyle="{StaticResource ListItemNullFocusContainerStyle}"
                                     ItemsSource="{Binding WorkRecords}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="210" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      Width="30"
                                                      Height="30"
                                                      Margin="0,0,0,0"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Background="Red"
                                                      FontSize="18"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay, NotifyOnSourceUpdated=True}"
                                                      Style="{StaticResource CheckBoxStyle}" />

                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       FontSize="18"
                                                       Text="{Binding WorkName}" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.人工拧螺丝}">
                                                                <Setter Property="StackPanel.Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.补拧}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.扫码输入}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.称重}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.放行}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.扫码}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.扫描员工卡}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.超时检测}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.涂胶检测}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.时间记录}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.用户输入}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.人工充气}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StationTaskType}" Value="{x:Static model:StationTaskTypeEnum.图示拧紧}">
                                                                <Setter Property="StackPanel.Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="18"
                                                           Text="返工数" />
                                                <ComboBox Grid.Column="3"
                                                          Width="80"
                                                          Margin="15,0,0,0"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"
                                                          HorizontalContentAlignment="Center"
                                                          FontSize="18"
                                                          ItemsSource="{Binding ReworkNums}"
                                                          SelectedIndex="0"
                                                          SelectedValue="{Binding ReworkNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Grid.Row="2"
                    Width="80"
                    Margin="0,20,40,0"
                    Background="ForestGreen"
                    Click="Button_Click_ChooseAll"
                    Content="全选" />
            <Button Grid.Row="2"
                    Margin="0,20,20,0"
                    HorizontalAlignment="Right"
                    Background="Gray"
                    Click="Button_Click_Cancle"
                    Content="取消" />
            <Button Grid.Row="2"
                    Width="100"
                    Margin="0,20,20,0"
                    Click="Button_Click"
                    Content="设置返工" />

        </StackPanel>

    </Grid>
</Window>
