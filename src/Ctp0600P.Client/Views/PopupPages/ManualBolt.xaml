<Window x:Class="Ctp0600P.Client.Views.StationTaskPages.ManualBolt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:validations="clr-namespace:Ctp0600P.Client.Validations"
        xmlns:viewmodels="clr-namespace:Ctp0600P.Client.ViewModels.StationTaskViewModels"
        Title="拧紧枪手动模式"
        Width="500"
        Height="400"
        d:DataContext="{d:DesignInstance Type=viewmodels:ManualBoltPageVM}"
        d:DesignHeight="450"
        d:DesignWidth="800"
        Background="{DynamicResource MaterialDesignPaper}"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <TextBlock Margin="10,0,0,0"
                   FontSize="14"
                   Foreground="OrangeRed"
                   Text="Tip：选中需要使用的拧紧枪,点击使能即可" />

        <Button Grid.Row="2"
                Width="100"
                Margin="0,20,20,0"
                HorizontalAlignment="Right"
                Click="Button_Click_Submit"
                Content="使能" />

        <ListBox Grid.Row="1"
                 ItemContainerStyle="{StaticResource ListItemNullFocusContainerStyle}"
                 ItemsSource="{Binding Path=StationBoltGunList}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  Margin="15,0,0,0"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  FontSize="18"
                                  IsChecked="{Binding IsSelected}" />

                        <Border Grid.Column="1"
                                Margin="5"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="LightBlue" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter Property="CornerRadius" Value="3" />
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="20*" />
                                    <RowDefinition Height="20*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>

                                    <!--  是否启用  -->
                                    <ColumnDefinition Width="60*" />
                                    <!--  枪号  -->
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="20" />
                                    <!--  程序号  -->
                                    <ColumnDefinition Width="60*" />
                                    <ColumnDefinition Width="60*" />

                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Content="启用"
                                          FlowDirection="RightToLeft"
                                          FontSize="18"
                                          IsChecked="{Binding IsSelected}" />
                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="枪号：" />
                                <TextBlock Grid.Column="2"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding Path=DeviceNo}" />
                                <TextBlock Grid.Column="3"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="程序号：" />
                                <TextBox Grid.Column="4"
                                         Height="40"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         FontSize="20"
                                         Style="{DynamicResource ValidationTextBoxStyle}"
                                         ToolTip="请输入正确的程序号">
                                    <TextBox.Text>
                                        <Binding Mode="TwoWay"
                                                 NotifyOnValidationError="True"
                                                 Path="ProgramNo"
                                                 UpdateSourceTrigger="PropertyChanged">
                                            <Binding.ValidationRules>
                                                <validations:PositiveIntegerRule ValidatesOnTargetUpdated="True" />
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox.Text>
                                </TextBox>
                            </Grid>
                        </Border>
                    </Grid>

                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


    </Grid>
</Window>
