<Window x:Class="Ctp0600P.Client.UserControls.PullStepBackPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ctp0600P.Client.UserControls"
        xmlns:app="clr-namespace:Ctp0600P.Client"
        Height="500" Width="600"
        WindowStyle="ToolWindow" 
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen" 
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:PullStepBackPageViewModel}"
        Title="拉站">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition  Height="*"/>
            <RowDefinition  Height="2*"/>
            <RowDefinition  Height="*"/>
            <RowDefinition  Height="40"/>
            <RowDefinition  Height="*"/>
            <RowDefinition  Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Content="AGV车号" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1"  FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Text="{Binding UserInput}"
                 Width="400" IsReadOnly="True"/>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <!--<Button Style="{Binding defaultBtnStyle}"   Grid.Column="0" Content="1" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"   Grid.Column="1" Content="2" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"   Grid.Column="2" Content="3" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"   Grid.Column="3" Content="4" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"   Grid.Column="4" Content="5" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"  Grid.Row="1"  Grid.Column="0" Content="6" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"  Grid.Row="1"   Grid.Column="1" Content="7" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"    Grid.Row="1" Grid.Column="2" Content="8" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"    Grid.Row="1" Grid.Column="3" Content="9" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"    Grid.Row="1" Grid.Column="4" Content="0" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>
            <Button Style="{Binding defaultBtnStyle}"   Grid.RowSpan="2" Grid.Column="10" Content="退格" FontSize="24" Margin="5" Command="{Binding NumerClick}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" ></Button>-->
        </Grid>

        <Label Grid.Row="4" Grid.Column="0" Content="Pack条码" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1"  FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Text="{Binding PackBarCode}" Height="40" Width="400"  IsReadOnly="True"/>
        <Label Grid.Row="2" Grid.Column="0" Content="出货码" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1"  FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Text="{Binding OutCode}"  Height="40" Width="400" IsReadOnly="True"/>
        <TextBlock Text="Tips：为确保【拉站】正确执行，请先扫描出货码！" Foreground="Red" Grid.Row="3" Grid.Column="1"  Width="500" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="21"></TextBlock>
        <Grid Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button  Content="确定拉站" Grid.Column="0" Click="Button_Click_PullStepBack" FontSize="18" MinWidth="200" MinHeight="50" FontWeight="Bold" HorizontalAlignment="Center"    IsEnabled="{Binding Enable}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{Binding defaultBtnStyle}"  Content="取消" Click="Button_Click" FontSize="18" MinWidth="200" MinHeight="50" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <!--<Button Grid.Column="0"  Content="扫码1" Command = "{Binding scan_1}"  FontSize="18" MinWidth="200" MinHeight="50" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>-->
                <!--<Button Grid.Column="1"  Content="扫码2" Command = "{Binding scan_2}"  FontSize="18" MinWidth="200" MinHeight="50" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>-->
            </Grid>

        </Grid>

    </Grid>
</Window>
