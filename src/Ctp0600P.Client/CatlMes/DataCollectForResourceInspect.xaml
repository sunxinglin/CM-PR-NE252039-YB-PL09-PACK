<UserControl x:Class="Ctp0600P.Client.CatlMes.DataCollectForResourceInspect"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chkIvt="clr-namespace:Catl.WebServices.DataCollectForResourceInspect;assembly=Catl.WebServices"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ctp0600P.Client.CatlMes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.Resources>
            <Style BasedOn="{StaticResource MaterialDesignLabel}" TargetType="Label">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,0,0" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="0,0,0,0" />
            </Style>
            <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style BasedOn="{StaticResource MaterialDesignTextBlock}" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Margin" Value="32,0,32,0" />
            </Style>
        </Grid.Resources>
        <GroupBox Grid.Row="0" Header="连接参数">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>


                <Label Grid.Row="0"
                       Grid.Column="0"
                       Content="工位" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Text="{Binding StationCode.Value}" />

                <Label Grid.Row="1"
                       Grid.Column="0"
                       Content="WSDL URL[MES服务器WSDL]" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding Url.Value}" />

                <Label Grid.Row="2"
                       Grid.Column="0"
                       Content="timeout[WS服务器连接超时设置 /ms]" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding Timeout.Value}" />

                <Label Grid.Row="3"
                       Grid.Column="0"
                       Content="UserName[连接服务器的用户名]" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Text="{Binding UserName.Value}" />

                <Label Grid.Row="4"
                       Grid.Column="0"
                       Content="Password[连接服务器的密码]" />
                <PasswordBox Name="passwdBox"
                             Grid.Row="4"
                             Grid.Column="1" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="接口参数">
            <Grid>
                <Grid.Resources />
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition />

                    <ColumnDefinition Width="210" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Label Grid.Row="0"
                       Grid.Column="0"
                       Content="site[设备所在的站点]" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Text="{Binding Site.Value}" />

                <Label Grid.Row="1"
                       Grid.Column="0"
                       Content="user[操作用户]" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding User.Value}" />

                <Label Grid.Row="2"
                       Grid.Column="0"
                       Content="operation[工位]" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding Operation.Value}" />

                <Label Grid.Row="3"
                       Grid.Column="0"
                       Content="operationRevision[工位版本]" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Text="{Binding OperationRevision.Value}" />

                <Label Grid.Row="4"
                       Grid.Column="0"
                       Content="dcGroup[DC采集组]" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Text="{Binding dcGroup.Value}" />

                <Label Grid.Row="5"
                       Grid.Column="0"
                       Content="dcGroupRevision[DC采集组版本号]" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Text="{Binding dcGroupRevision.Value}" />



                <Label Grid.Row="0"
                       Grid.Column="2"
                       Content="executeMode[首件模式]" />
                <TextBox Grid.Row="0"
                         Grid.Column="3"
                         Text="{Binding executeMode.Value}" />

                <Label Grid.Row="1"
                       Grid.Column="2"
                       Content="Resource[资源号]" />
                <TextBox Grid.Row="1"
                         Grid.Column="3"
                         Text="{Binding Resource.Value}" />

                <Label Grid.Row="2"
                       Grid.Column="2"
                       Content="ActivityId" />
                <TextBox Grid.Row="2"
                         Grid.Column="3"
                         Text="{Binding ActivityId.Value}" />
                <Label Grid.Row="3"
                       Grid.Column="2"
                       Content="dcMode[DC组获取方式]" />
                <TextBox Grid.Row="3"
                         Grid.Column="3"
                         Text="{Binding dcMode.Value}" />
                <Label Grid.Row="4"
                       Grid.Column="2"
                       Content="dcSequence[DC组获取方式]" />
                <TextBox Grid.Row="4"
                         Grid.Column="3"
                         Text="{Binding dcSequence.Value}" />




                <Button Grid.Row="6"
                        Grid.Column="0"
                        Width="100"
                        Background="Salmon"
                        Command="{Binding CmdSave}"
                        CommandParameter="{Binding ElementName=passwdBox}"
                        Content="保存" />
                <Button Grid.Row="6"
                        Grid.Column="1"
                        Width="100"
                        Background="OldLace"
                        Command="{Binding CmdReload}"
                        CommandParameter="{Binding ElementName=passwdBox}"
                        Content="刷新"
                        Foreground="{StaticResource PrimaryHueDarkBrush}" />

                <!--<Button Content="测试" Command="{Binding CmdTest}"  HorizontalAlignment="Left"
                     CommandParameter="{Binding ElementName=passwdBox}"
                     Foreground="{StaticResource PrimaryHueDarkBrush}" Background="Salmon" Width="100" Grid.Row="6" Grid.Column="2"></Button>-->

            </Grid>

        </GroupBox>

    </Grid>
</UserControl>
