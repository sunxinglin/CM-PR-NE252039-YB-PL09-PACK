<UserControl x:Class="Ctp0600P.Client.UserCtrls.StationTaskHearderInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Ctp0600P.Client.UserCtrls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid MaxHeight="120" MinHeight="50">
        <Grid.RowDefinitions>
            <RowDefinition Height="10*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Border Background="{Binding BackBrush}" Grid.Row="0" d:Background="AliceBlue" Margin="10,10,0,5">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4"
                                  Color="Black"
                                  Opacity="0.4"
                                  BlurRadius="20" RenderingBias="Performance" />
            </Border.Effect>
            <TextBlock TextWrapping="Wrap" Text="{Binding Info}" FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold" />

        </Border>
        <local:ArrowUC Grid.Row="1" HorizontalAlignment="Center" Visibility="{Binding ArrowVisi}" />
    </Grid>
</UserControl>