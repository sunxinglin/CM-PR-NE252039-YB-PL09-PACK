<UserControl x:Class="Ctp0600P.Client.UserCtrls.DeviceSettingsUserCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Ctp0600P.Client.UserCtrls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Header="设备配置" Style="{DynamicResource MaterialDesignGroupBox}" Margin="8" FontSize="24"
                            md:ColorZoneAssist.Mode="Custom"
                            md:ColorZoneAssist.Background="Black"
                            md:ColorZoneAssist.Foreground="White">
        </GroupBox>
    </Grid>
</UserControl>
